---
import Layout from '../layouts/Layout.astro';
import Waybar from '../components/Waybar.astro';
import Footer from '../components/Footer.astro';
import ProjectHero from '../components/project-blocks/ProjectHero.astro';
import ProjectGallery from '../components/project-blocks/ProjectGallery.astro';
import ProjectTextBlock from '../components/project-blocks/ProjectTextBlock.astro';
import ProjectMeta from '../components/project-blocks/ProjectMeta.astro';
import ProjectIntro from '../components/project-blocks/ProjectIntro.astro';
import ProjectCallout from '../components/project-blocks/ProjectCallout.astro';
import ProjectQuote from '../components/project-blocks/ProjectQuote.astro';
import ProjectMetricsBand from '../components/project-blocks/ProjectMetricsBand.astro';
import ProjectBeforeAfter from '../components/project-blocks/ProjectBeforeAfter.astro';
import ProjectLearnings from '../components/project-blocks/ProjectLearnings.astro';
import ProjectProcessSteps from '../components/project-blocks/ProjectProcessSteps.astro';
import ProjectFindingsGrid from '../components/project-blocks/ProjectFindingsGrid.astro';
import ProjectHowMightWe from '../components/project-blocks/ProjectHowMightWe.astro';
import ProjectDecisionLog from '../components/project-blocks/ProjectDecisionLog.astro';
import ProjectPersona from '../components/project-blocks/ProjectPersona.astro';
import ProjectProblemKeyInfo from '../components/project-blocks/ProjectProblemKeyInfo.astro';
import ProjectTextImage from '../components/project-blocks/ProjectTextImage.astro';
import ProjectImageGalleryGrid from '../components/project-blocks/ProjectImageGalleryGrid.astro';
import ProjectAccessibilityAudit from '../components/project-blocks/ProjectAccessibilityAudit.astro';
import MoreProjects from '../components/project-blocks/MoreProjects.astro';

const sampleImage = '/images/img_01_before_after.svg';
---

<Layout title="Block library — Nirmal">
  <Waybar />

  <ProjectHero title="Block Library Demo" type="UI Kit" year="2026" />

  <ProjectMeta
    statusline={[
      { label: 'DEMO', lime: true },
      { label: 'project blocks' },
      { label: 'kitchen sink' },
    ]}
  />

  <ProjectTextBlock heading="proj_text_block">
    Every reusable block used in case studies, rendered here with sample content for quick reference.
  </ProjectTextBlock>

  <ProjectIntro
    eyebrow="Project intro"
    title="A reusable section header"
    summary="Used at the top of a project section to set context before diving into detail."
    trailingLabel="Optional trailing label"
  />

  <ProjectGallery image={sampleImage} imageAlt="Sample gallery image" />

  <ProjectCallout
    label="Insight"
    body="This is an insight callout — used to surface a key research finding or principle."
    variant="insight"
  />

  <ProjectCallout
    label="Principle"
    body="This is a principle callout — a slightly heavier emphasis treatment."
    variant="principle"
  />

  <ProjectCallout
    label="Warning"
    body="This is a warning callout — used to flag risks, constraints, or trade-offs."
    variant="warning"
  />

  <ProjectQuote
    quote="A short standout quote pulled from research or stakeholder feedback."
    attribution="Participant 04 — usability session"
  />

  <ProjectMetricsBand
    items={[
      { value: '42%', label: 'Drop in checkout abandonment' },
      { value: '11', label: 'Stakeholder interviews conducted' },
      { value: '3.2x', label: 'Increase in task completion rate' },
      { value: '6 wks', label: 'From research to shipped redesign' },
    ]}
  />

  <ProjectBeforeAfter
    beforeTitle="Cluttered review screen"
    beforeBody="Users had to scroll past unrelated information before reaching the confirm button."
    afterTitle="Focused summary"
    afterBody="Key details surfaced first, with a single clear call to action."
  />

  <ProjectTextImage
    eyebrow="Text + image"
    title="Side-by-side layout"
    body="Pairs a block of text with an image, useful for walking through a specific screen or flow step."
    image={sampleImage}
    imageAlt="Sample text/image pairing"
  />

  <ProjectTextImage
    eyebrow="Reversed"
    title="Image on the left"
    body="Same component with the reverse prop set — image and text swap sides."
    image={sampleImage}
    imageAlt="Sample reversed text/image pairing"
    reverse
  />

  <ProjectProcessSteps
    title="Process steps"
    steps={[
      { title: 'Discover', body: 'Talk to users and stakeholders to understand the problem space.' },
      { title: 'Define', body: 'Synthesise findings into clear problem statements.' },
      { title: 'Design', body: 'Prototype and iterate on solutions.' },
      { title: 'Deliver', body: 'Ship, measure, and refine.' },
    ]}
  />

  <ProjectFindingsGrid
    title="Findings"
    items={[
      { title: 'Trust matters most', body: 'Users hesitated when the interface felt impersonal.' },
      { title: 'Speed beats polish', body: 'A faster flow was valued over a prettier one.' },
      { title: 'Clarity over choice', body: 'Fewer, clearer options reduced drop-off.' },
    ]}
  />

  <ProjectHowMightWe
    intro="A few of the framing questions that guided exploration."
    items={[
      { question: 'How might we make onboarding feel personal?', theme: 'Onboarding' },
      { question: 'How might we reduce cognitive load at checkout?', theme: 'Checkout' },
      { question: 'How might we build trust before sign-up?', theme: 'Trust' },
    ]}
  />

  <ProjectPersona
    name="Maya"
    role="First-time pet owner"
    quote="I just want to know I'm covered without reading a 20-page policy."
    goals={["Get insured quickly", "Understand what's covered"]}
    frustrations={["Jargon-heavy policy documents", "Too many steps to confirm"]}
    context="Maya signed up after a vet recommended pet insurance for her new puppy."
    contextTags={["Mobile", "First-time buyer"]}
  />

  <ProjectProblemKeyInfo
    problemBody="Users abandoned the review screen before completing checkout, with drop-off concentrated on mobile."
    contextBody="The review screen needed to build confidence in seconds, not minutes."
    infoItems={[
      { label: 'Platform', value: 'Mobile web' },
      { label: 'Timeline', value: '6 weeks' },
      { label: 'Constraint', value: 'FCA compliance' },
    ]}
  />

  <ProjectImageGalleryGrid
    title="Gallery grid"
    images={[
      { src: sampleImage, alt: 'Sample screen one' },
      { src: sampleImage, alt: 'Sample screen two' },
    ]}
  />

  <ProjectAccessibilityAudit
    intro="A sample of audit findings with severity ratings and suggested fixes."
    issues={[
      {
        issue: 'Low contrast body text',
        description: 'Body copy on the summary card fails WCAG AA contrast requirements.',
        severity: 'serious',
        wcagCriterion: 'WCAG 1.4.3',
        fix: 'Darken text colour to meet 4.5:1 contrast ratio.',
      },
      {
        issue: 'Missing form labels',
        description: 'Input fields rely on placeholder text only.',
        severity: 'critical',
        wcagCriterion: 'WCAG 1.3.1',
        fix: 'Add visible <label> elements for each input.',
      },
      {
        issue: 'Decorative icon announced',
        description: 'Screen readers announce a purely decorative icon.',
        severity: 'minor',
        fix: 'Add aria-hidden="true" to the icon.',
      },
    ]}
  />

  <ProjectDecisionLog
    intro="A few example decisions and their outcomes."
    decisions={[
      {
        decision: 'Use a single-page checkout instead of multi-step',
        rationale: 'Reduced drop-off observed in earlier multi-step prototypes.',
        outcome: 'Completion rate increased by 18%.',
        outcomeType: 'positive',
      },
      {
        decision: 'Defer optional add-ons to a post-purchase screen',
        rationale: 'Kept the primary flow focused on the core decision.',
        outcome: 'Add-on attach rate dropped slightly but checkout speed improved.',
        outcomeType: 'tradeoff',
      },
      {
        decision: 'Keep the existing colour palette',
        rationale: 'Brand guidelines required minimal visual changes.',
        outcome: 'No measurable impact on usability.',
        outcomeType: 'neutral',
      },
    ]}
  />

  <ProjectLearnings
    title="Learnings"
    points={[
      'Early prototype testing surfaced issues that would have been costly to fix post-launch.',
      'Small copy changes had an outsized effect on user confidence.',
      'Cross-functional reviews early in the process reduced rework later.',
    ]}
  />

  <MoreProjects
    title="More projects"
    projects={[
      {
        title: 'Pet Insurance Checkout Redesign',
        blurb: 'Rebuilt the review screen around what 11 internal interviews actually said.',
        slug: 'pet-insurance-checkout',
        category: 'UI / UX',
      },
      {
        title: 'Perro Onboarding & Subscription',
        blurb: 'Redesigned and built the onboarding flow in Flutter, research through to production.',
        slug: 'perro-onboarding',
        category: 'UX / Flutter',
      },
    ]}
  />

  <Footer />
</Layout>
