---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Waybar from '../../components/Waybar.astro';
import Footer from '../../components/Footer.astro';
import ProjectHero from '../../components/project-blocks/ProjectHero.astro';
import ProjectGallery from '../../components/project-blocks/ProjectGallery.astro';
import ProjectTextBlock from '../../components/project-blocks/ProjectTextBlock.astro';
import ProjectMeta from '../../components/project-blocks/ProjectMeta.astro';
import ProjectIntro from '../../components/project-blocks/ProjectIntro.astro';
import ProjectCallout from '../../components/project-blocks/ProjectCallout.astro';
import ProjectQuote from '../../components/project-blocks/ProjectQuote.astro';
import ProjectMetricsBand from '../../components/project-blocks/ProjectMetricsBand.astro';
import ProjectBeforeAfter from '../../components/project-blocks/ProjectBeforeAfter.astro';
import ProjectLearnings from '../../components/project-blocks/ProjectLearnings.astro';
import ProjectProcessSteps from '../../components/project-blocks/ProjectProcessSteps.astro';
import ProjectFindingsGrid from '../../components/project-blocks/ProjectFindingsGrid.astro';
import ProjectHowMightWe from '../../components/project-blocks/ProjectHowMightWe.astro';
import ProjectDecisionLog from '../../components/project-blocks/ProjectDecisionLog.astro';
import ProjectPersona from '../../components/project-blocks/ProjectPersona.astro';
import ProjectProblemKeyInfo from '../../components/project-blocks/ProjectProblemKeyInfo.astro';
import ProjectTextImage from '../../components/project-blocks/ProjectTextImage.astro';
import ProjectImageGalleryGrid from '../../components/project-blocks/ProjectImageGalleryGrid.astro';
import ProjectAccessibilityAudit from '../../components/project-blocks/ProjectAccessibilityAudit.astro';
import MoreProjects from '../../components/project-blocks/MoreProjects.astro';
import WindowChrome from '../../components/WindowChrome.astro';
import VimStatusline from '../../components/VimStatusline.astro';
import '../../styles/jargon.css';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const tldrEntry = await getEntry('projectTldrs', project.id);
const TldrContent = tldrEntry ? (await render(tldrEntry)).Content : null;

const blockComponents = {
  ProjectHero,
  ProjectGallery,
  ProjectTextBlock,
  ProjectMeta,
  ProjectIntro,
  ProjectCallout,
  ProjectQuote,
  ProjectMetricsBand,
  ProjectBeforeAfter,
  ProjectLearnings,
  ProjectProcessSteps,
  ProjectFindingsGrid,
  ProjectHowMightWe,
  ProjectDecisionLog,
  ProjectPersona,
  ProjectProblemKeyInfo,
  ProjectTextImage,
  ProjectImageGalleryGrid,
  ProjectAccessibilityAudit,
  MoreProjects,
};

const sections = project.data.sections ?? [
  { component: 'ProjectHero' as const, props: { title: project.data.title, type: project.data.type, year: project.data.year } },
  { component: 'ProjectGallery' as const, props: { image: project.data.image, imageAlt: project.data.imageAlt } },
  { component: 'ProjectMeta' as const, props: { statusline: project.data.statusline } },
];

const outsideSections = sections.filter((s) => s.component === 'ProjectHero' || s.component === 'MoreProjects');
const bodySections = sections.filter((s) => s.component !== 'ProjectHero' && s.component !== 'MoreProjects');
const heroSections = outsideSections.filter((s) => s.component === 'ProjectHero');
const moreProjectsSections = outsideSections.filter((s) => s.component === 'MoreProjects');

const caseStudyFilename = `crafting-${project.id}.md`;
---

<Layout title={`${project.data.title} — Nirmal`}>
  <Waybar />
  <main id="main-content">
  <div class="proj-page">
    {heroSections.map((section) => {
      const Component = blockComponents[section.component];
      return <Component {...(section.props ?? {})} />;
    })}
    <div class="proj-window vim-window">
      <WindowChrome title={caseStudyFilename} activeTitle="[+]" icon="UTF-8">
        <Fragment slot="actions">
          {TldrContent && (
            <div class="tldr-hint-wrap">
              <button class="win-tldr" type="button" aria-pressed="false">
                <span class="win-tldr-label">tldr</span>
                <span class="win-tldr-track"><span class="win-tldr-thumb"></span></span>
              </button>
              <div class="tldr-hint" id="tldr-hint" role="status">
                <span class="tldr-hint-dot">●</span>
                <span class="tldr-hint-text">too long? flip this for the short version</span>
                <button class="tldr-hint-close" id="tldr-hint-close" type="button" aria-label="Dismiss hint">×</button>
              </div>
            </div>
          )}
        </Fragment>
        <div class="proj-window-body vim-window-body">
          <div class="proj-full">
            {bodySections.map((section) => {
              const Component = blockComponents[section.component];
              return <Component {...(section.props ?? {})} />;
            })}
            <ProjectTextBlock>
              <Content />
            </ProjectTextBlock>
          </div>
          {TldrContent && (
            <div class="proj-tldr" hidden>
              <ProjectTextBlock heading="tldr">
                <TldrContent />
              </ProjectTextBlock>
            </div>
          )}
        </div>
        <VimStatusline filename={caseStudyFilename} />
      </WindowChrome>
    </div>
    {moreProjectsSections.map((section) => {
      const Component = blockComponents[section.component];
      return <Component {...(section.props ?? {})} />;
    })}
  </div>
  </main>
  <Footer />
</Layout>

<style>
  .proj-page {
    max-width: 1440px;
    margin: 0 auto;
    scroll-snap-type: y proximity;
  }

  .proj-window {
    padding: 0 3rem 3rem;
    scroll-snap-align: center;
  }

  .proj-window :global(.window) {
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--bar-h) - 2rem);
    position: sticky;
    top: calc(var(--bar-h) + 1rem);
  }

  .proj-window-body {
    background: var(--bg1);
    padding-top: 2rem;
    overflow-y: hidden;
    flex: 1;
    min-height: 0;
  }

  .proj-full,
  .proj-tldr {
    animation: proj-fade-in 0.18s ease-out;
  }

  @keyframes proj-fade-in {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .proj-full,
    .proj-tldr {
      animation: none;
    }
  }

  .tldr-hint-wrap {
    position: relative;
  }

  .win-tldr {
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: 1px solid var(--lime);
    border-radius: 3px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--lime);
    padding: 4px 8px;
    transition: box-shadow 0.15s;
  }

  .win-tldr.attn {
    animation: tldr-pulse 1.6s ease-out 2;
  }

  @keyframes tldr-pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--lime) 55%, transparent); }
    100% { box-shadow: 0 0 0 8px color-mix(in srgb, var(--lime) 0%, transparent); }
  }

  .tldr-hint {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--bg2);
    border: 1px solid var(--lime);
    border-radius: 3px;
    padding: 6px 8px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text);
    white-space: nowrap;
    z-index: 150;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
    box-shadow: 0 4px 14px rgba(0,0,0,0.35);
  }

  .tldr-hint::before {
    content: '';
    position: absolute;
    top: -5px;
    right: 10px;
    width: 8px;
    height: 8px;
    background: var(--bg2);
    border-left: 1px solid var(--lime);
    border-top: 1px solid var(--lime);
    transform: rotate(45deg);
  }

  .tldr-hint.show {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .tldr-hint-dot {
    color: var(--lime);
    font-size: 9px;
  }

  .tldr-hint-close {
    background: none;
    border: none;
    color: var(--dim);
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1;
    cursor: pointer;
    padding: 0 0 0 4px;
  }

  .tldr-hint-close:hover { color: var(--lime); }

  @media (prefers-reduced-motion: reduce) {
    .win-tldr.attn { animation: none; }
  }

  @media (max-width: 860px) {
    .tldr-hint { display: none; }
  }

  .win-tldr:hover {
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--lime) 25%, transparent);
  }

  .win-tldr-track {
    width: 20px;
    height: 11px;
    border: 1px solid var(--lime);
    border-radius: 6px;
    position: relative;
    flex-shrink: 0;
    transition: background 0.15s;
  }

  .win-tldr-thumb {
    position: absolute;
    top: 1px;
    left: 1px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--lime);
    transition: transform 0.15s;
  }

  .win-tldr[aria-pressed='true'] .win-tldr-track {
    background: var(--lime);
  }

  .win-tldr[aria-pressed='true'] .win-tldr-thumb {
    background: var(--bg0);
    transform: translateX(9px);
  }

  @media (max-width: 860px) {
    .proj-window { padding: 0 1.25rem 2rem; height: auto !important; }
    .proj-window :global(.window) { height: auto; position: static; }
    .proj-window-body { overflow-y: visible; flex: none; }
  }

  @media (max-width: 480px) {
    .proj-window { padding: 0 0.75rem 1.5rem; }
  }
</style>

<script>
  import { initVimWindow } from '../../lib/vim-window';
  initVimWindow();
</script>

<script>
  (function () {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.jargon-term');
    if (buttons.length === 0) return;

    const isTouch = () => window.matchMedia('(hover: none)').matches;
    const GAP = 8;
    const EDGE = 8;

    let openButton: HTMLButtonElement | null = null;

    const tipFor = (button: HTMLButtonElement) => {
      const id = button.getAttribute('aria-describedby');
      return id ? document.getElementById(id) : null;
    };

    const position = (button: HTMLButtonElement, tip: HTMLElement) => {
      const btnRect = button.getBoundingClientRect();
      const tipRect = tip.getBoundingClientRect();

      let top = btnRect.top - tipRect.height - GAP;
      if (top < EDGE) top = btnRect.bottom + GAP;

      let left = btnRect.left + btnRect.width / 2 - tipRect.width / 2;
      left = Math.max(EDGE, Math.min(left, window.innerWidth - tipRect.width - EDGE));

      tip.style.top = `${top}px`;
      tip.style.left = `${left}px`;
    };

    const close = (button: HTMLButtonElement | null) => {
      if (!button) return;
      const tip = tipFor(button);
      button.setAttribute('aria-expanded', 'false');
      tip?.classList.remove('open');
      if (tip) {
        tip.style.top = '-9999px';
        tip.style.left = '-9999px';
      }
      if (openButton === button) openButton = null;
    };

    const open = (button: HTMLButtonElement) => {
      const tip = tipFor(button);
      if (!tip) return;
      if (openButton && openButton !== button) close(openButton);
      button.setAttribute('aria-expanded', 'true');
      tip.classList.add('open');
      position(button, tip);
      openButton = button;
    };

    buttons.forEach((button) => {
      if (isTouch()) {
        button.addEventListener('click', (e) => {
          e.stopPropagation();
          if (openButton === button) close(button);
          else open(button);
        });
        return;
      }

      button.addEventListener('mouseenter', () => open(button));
      button.addEventListener('mouseleave', () => {
        if (document.activeElement !== button) close(button);
      });
      button.addEventListener('focus', () => open(button));
      button.addEventListener('blur', () => close(button));
    });

    document.addEventListener('click', (e) => {
      if (!openButton) return;
      if (e.target instanceof Node && openButton.contains(e.target)) return;
      close(openButton);
    });

    window.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape' || !openButton) return;
      const button = openButton;
      close(button);
      button.focus();
    });

    window.addEventListener(
      'resize',
      () => {
        if (openButton) close(openButton);
      },
      { passive: true }
    );
  })();
</script>
