---
import Layout from '../layouts/Layout.astro';
import Waybar from '../components/Waybar.astro';
import Footer from '../components/Footer.astro';
import WindowChrome from '../components/WindowChrome.astro';
import BackToHome from '../components/BackToHome.astro';
import { timeline } from '../data/timeline.ts';

const base = import.meta.env.BASE_URL;

const lookingFor = [
  { label: 'Role', value: 'Product Designer / UX Designer — research-led, comfortable building' },
  { label: 'Level', value: 'Junior, moving toward mid-level' },
  { label: 'Domains', value: 'Fintech & insurance, health-adjacent products, anything with real constraints and real-world impact for users' },
  { label: 'Ways of working', value: 'Remote/hybrid-friendly, UK-based. Happy embedded in a product team or owning research and UX end-to-end.' },
  { label: 'What I bring', value: 'Research that changes the design, not research that decorates it. The ability to prototype and build, so ideas could get tested in the real product instead of a static prototype.' },
];
---

<Layout title="About — Nirmal">
  <Waybar />

  <main id="main-content">
  <section class="about-hero grid-bg">
    <div class="back-home-row"><BackToHome /></div>
    <div class="about-photo" aria-hidden="true">
      <span class="about-photo-todo">TODO: headshot</span>
    </div>
    <div class="about-intro">
      <h1 class="about-h1">Nirmal Karthikeyan</h1>
      <p class="about-lede">
      I'm a product designer with a penchant for what's new, but with the attention to detail to still ensure that 
      every scenario gets accounted for. You'll find me urgently scribbling down ideas for new features while I'm running 
      usability sessions evaluating forms. My processes are constantly evolving as I learn more about the world of UX, but 
      my decisions are always backed by good research within the constraints of what's possible. I can design detailed components
      and complete design systems and prototype new features in code for testing. Good design, to me, is about being honest 
      with users and always keeping in mind that I'm not the end-user. 
      </p>
    </div>
  </section>

  <section class="looking-for grid-bg">
    <WindowChrome title="~/about — looking_for.json">
      <dl class="lf-panel">
        {lookingFor.map((item) => (
          <div class="lf-row">
            <dt class="lf-label">{item.label}</dt>
            <dd class="lf-value">{item.value}</dd>
          </div>
        ))}
      </dl>
    </WindowChrome>
  </section>

  <section class="timeline-section grid-bg">
    <WindowChrome title="~/about — career_timeline.json">
      <div class="tl-panel">
        <h2 class="section-h2">Career timeline</h2>
        <ol class="timeline">
          {timeline.map((entry) => (
            <li class="tl-entry">
              <div class="tl-dot" aria-hidden="true"></div>
              <div class="tl-content">
                <div class="tl-headline">
                  <span class="tl-org">{entry.org}</span>
                  <span class="tl-title">{entry.title}</span>
                  <span class="tl-dates">{entry.dates}</span>
                </div>
                <p class="tl-body">{entry.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </WindowChrome>
  </section>

  <section class="beyond-work grid-bg">
    <WindowChrome title="~/about — beyond_work.md">
      <div class="beyond-panel">
        <h2 class="section-h2">Beyond the work</h2>
        <p class="beyond-body">
          When I'm not designing, I read, I write about product and UX and computers on
          <a href="https://medium.com/@nirmalkarthikeyan" target="_blank" rel="noopener">Medium</a>,
          I build small things for fun, mostly so I don't forget my CS roots, and explore the changing world of technology.
        </p>
      </div>
    </WindowChrome>
  </section>

  <section class="about-cta grid-bg">
    <span class="cta-text">Open for collaboration.</span>
    <a href={`${base}contact`} class="cta-link">Get in touch</a>
    <span class="cta-sep">·</span>
    <a href={`${base}Resume.pdf`} target="_blank" rel="noopener" class="cta-link">View CV</a>
  </section>
  </main>

  <Footer />
</Layout>

<style>
  .about-hero {
    padding: 4rem 3rem 3rem;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .back-home-row {
    grid-column: 1 / -1;
    margin-bottom: -0.5rem;
  }

  .about-photo {
    width: 220px;
    height: 220px;
    border-radius: var(--radius-md);
    border: 1px dashed var(--border-hi);
    background: var(--bg1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .about-photo-todo {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--dim);
    text-align: center;
    padding: 0 1rem;
  }

  .about-h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--lime);
    margin-bottom: 1.25rem;
  }

  .about-lede {
    font-size: 1.0625rem;
    color: var(--sub);
    line-height: 1.7;
    max-width: 62ch;
  }

  .looking-for {
    padding: 0 3rem 3rem;
  }

  .lf-panel {
    background: var(--bg1);
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
  }

  .lf-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .lf-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .lf-row:first-child {
    padding-top: 0;
  }

  .lf-label {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--lime);
  }

  .lf-value {
    font-size: 0.9375rem;
    color: var(--text);
    line-height: 1.6;
  }

  .section-h2 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .timeline-section {
    padding: 0 3rem 3rem;
  }

  .tl-panel {
    background: var(--bg1);
    padding: 1.75rem 2rem;
  }

  .timeline {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  .tl-entry {
    display: grid;
    grid-template-columns: 20px 1fr;
    gap: 1.5rem;
    padding-bottom: 2rem;
    position: relative;
  }

  .tl-entry::before {
    content: '';
    position: absolute;
    left: 9px;
    top: 22px;
    bottom: -4px;
    width: 1px;
    background: var(--border);
  }

  .tl-entry:last-child::before {
    display: none;
  }

  .tl-dot {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 1px solid var(--lime);
    background: var(--lime-dim);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tl-dot::after {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--lime);
  }

  .tl-headline {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }

  .tl-org {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text);
  }

  .tl-title {
    font-size: 0.9375rem;
    color: var(--lime);
    font-family: var(--mono);
  }

  .tl-dates {
    font-size: 0.8125rem;
    color: var(--dim);
    font-family: var(--mono);
    margin-left: auto;
  }

  .tl-body {
    font-size: 0.9375rem;
    color: var(--sub);
    line-height: 1.65;
    max-width: 62ch;
  }

  .tl-note {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--dim);
  }

  .beyond-work {
    padding: 0 3rem 3rem;
  }

  .beyond-panel {
    background: var(--bg1);
    padding: 1.75rem 2rem;
  }

  .beyond-body {
    font-size: 0.9375rem;
    color: var(--sub);
    line-height: 1.7;
    max-width: 62ch;
  }

  .beyond-body a {
    color: var(--lime);
    text-decoration: none;
    border-bottom: 1px solid rgba(158,255,87,0.35);
  }

  .beyond-body a:hover {
    border-bottom-color: var(--lime);
  }

  .about-cta {
    padding: 0 3rem 4rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--mono);
    font-size: 0.9375rem;
  }

  .cta-text {
    color: var(--sub);
  }

  .cta-link {
    color: var(--lime);
    text-decoration: none;
    border-bottom: 1px solid rgba(158,255,87,0.35);
  }

  .cta-link:hover {
    border-bottom-color: var(--lime);
  }

  .cta-sep {
    color: var(--dim);
  }

  @media (max-width: 860px) {
    .about-hero { padding: 2.5rem 1.25rem 2rem; grid-template-columns: 1fr; }
    .about-photo { width: 140px; height: 140px; }
    .looking-for { padding: 0 1.25rem 2rem; }
    .timeline-section { padding: 0 1.25rem 2rem; }
    .beyond-work { padding: 0 1.25rem 2rem; }
    .about-cta { padding: 0 1.25rem 3rem; flex-wrap: wrap; }
  }

  @media (max-width: 480px) {
    .about-hero { padding: 1.75rem 0.75rem 1.5rem; }
    .looking-for { padding: 0 0.75rem 1.5rem; }
    .lf-row { grid-template-columns: 1fr; gap: 0.4rem; }
    .timeline-section { padding: 0 0.75rem 1.5rem; }
    .tl-panel { padding: 1.25rem 1rem; }
    .tl-dates { margin-left: 0; }
    .beyond-work { padding: 0 0.75rem 1.5rem; }
    .beyond-panel { padding: 1.25rem 1rem; }
    .about-cta { padding: 0 0.75rem 2rem; }
  }
</style>
