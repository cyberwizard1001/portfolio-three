---
interface RelatedProject {
  title: string;
  blurb: string;
  slug: string;
  category: string;
}

interface Props {
  title: string;
  projects: RelatedProject[];
}

const { title, projects } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="proj-more">
  <h2 class="proj-more-title">{title}</h2>
  <p class="proj-more-intro">
    A few other projects from the portfolio that explore adjacent product, service, and UX problems.
  </p>
  <div class="proj-more-grid">
    {projects.map((project) => (
      <a class="proj-more-card" href={`${base}projects/${project.slug}`}>
        <span class="proj-more-category">{project.category}</span>
        <h3 class="proj-more-card-title">{project.title}</h3>
        <p class="proj-more-blurb">{project.blurb}</p>
        <span class="proj-more-cta">View project →</span>
      </a>
    ))}
  </div>
</section>

<style>
  .proj-more {
    padding: 0 3rem 3rem;
  }

  .proj-more-title {
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .proj-more-intro {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.6;
    max-width: 760px;
    margin-bottom: 1.5rem;
  }

  .proj-more-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .proj-more-card {
    display: flex;
    flex-direction: column;
    min-height: 220px;
    border: 1px solid var(--border-hi);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.18s ease, background 0.18s ease;
  }

  .proj-more-card:hover {
    border-color: var(--lime);
    background: rgba(255,255,255,0.06);
  }

  .proj-more-category {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--lime);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .proj-more-card-title {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .proj-more-blurb {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.6;
    flex-grow: 1;
  }

  .proj-more-cta {
    margin-top: 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
  }

  .proj-more-card:hover .proj-more-cta {
    color: var(--lime);
  }

  @media (max-width: 1100px) {
    .proj-more-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 700px) {
    .proj-more-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 860px) {
    .proj-more { padding: 0 1.25rem 2rem; }
  }
</style>
