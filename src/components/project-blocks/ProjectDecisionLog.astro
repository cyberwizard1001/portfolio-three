---
interface DecisionItem {
  decision: string;
  rationale: string;
  outcome: string;
  outcomeType?: 'positive' | 'neutral' | 'tradeoff';
}

interface Props {
  decisions: DecisionItem[];
  title?: string;
  intro?: string;
}

const { decisions, title = 'Decision log', intro } = Astro.props;

const outcomeLabels: Record<string, string> = {
  positive: 'Positive',
  neutral: 'Neutral',
  tradeoff: 'Trade-off',
};
---

<section class="proj-dlog">
  <h2 class="proj-dlog-title">{title}</h2>
  {intro && <p class="proj-dlog-intro">{intro}</p>}
  <div class="proj-dlog-list">
    {decisions.map((d, i) => {
      const type = d.outcomeType ?? 'neutral';
      return (
        <div class:list={['proj-dlog-card', `proj-dlog-card-${type}`]}>
          <div class="proj-dlog-head">
            <span class="proj-dlog-num">{i + 1}</span>
            <h3 class="proj-dlog-decision">{d.decision}</h3>
            <span class:list={['proj-dlog-chip', `proj-dlog-${type}`]}>{outcomeLabels[type]}</span>
          </div>
          <div class="proj-dlog-body">
            <p class="proj-dlog-rationale">{d.rationale}</p>
            <div class="proj-dlog-outcome">
              <span class="proj-dlog-outcome-label">Result</span>
              <p class="proj-dlog-outcome-text">{d.outcome}</p>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .proj-dlog {
    padding: 0 3rem 3rem;
  }

  .proj-dlog-title {
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .proj-dlog-intro {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 720px;
  }

  .proj-dlog-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .proj-dlog-card {
    border: 1px solid var(--border-hi);
    border-left: 3px solid var(--border-hi);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    background: var(--bg1);
    transition: border-color 0.15s ease;
  }

  .proj-dlog-card-positive { border-left-color: rgba(30,158,97,0.45); }
  .proj-dlog-card-neutral  { border-left-color: rgba(158,255,87,0.35); }
  .proj-dlog-card-tradeoff { border-left-color: rgba(217,119,6,0.45); }

  .proj-dlog-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
  }

  .proj-dlog-num {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--lime-dim);
    color: var(--lime);
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 700;
    align-self: center;
  }

  .proj-dlog-decision {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
    flex: 1;
  }

  .proj-dlog-chip {
    flex-shrink: 0;
    display: inline-block;
    width: fit-content;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    border-radius: 999px;
    padding: 3px 10px;
    border: 1px solid transparent;
    align-self: center;
  }

  .proj-dlog-positive {
    color: #1e9e61;
    background: rgba(30,158,97,0.12);
    border-color: rgba(30,158,97,0.25);
  }

  .proj-dlog-neutral {
    color: var(--lime);
    background: var(--lime-dim);
    border-color: rgba(158,255,87,0.25);
  }

  .proj-dlog-tradeoff {
    color: #d97706;
    background: rgba(217,119,6,0.12);
    border-color: rgba(217,119,6,0.25);
  }

  .proj-dlog-body {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 0 2rem;
    padding-left: calc(26px + 0.75rem);
  }

  .proj-dlog-rationale {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.65;
  }

  .proj-dlog-outcome {
    border-left: 1px solid var(--border);
    padding-left: 1.25rem;
  }

  .proj-dlog-outcome-label {
    display: block;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 0.4rem;
  }

  .proj-dlog-outcome-text {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .proj-dlog { padding: 0 1.25rem 2rem; }

    .proj-dlog-body {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding-left: 0;
    }

    .proj-dlog-outcome {
      border-left: none;
      padding-left: 0;
      padding-top: 0.75rem;
      border-top: 1px solid var(--border);
    }
  }
</style>
