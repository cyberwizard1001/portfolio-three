---
import { jargonify } from '../../lib/jargon';

interface DecisionItem {
  decision: string;
  rationale: string;
  outcome: string;
  outcomeType?: 'positive' | 'neutral' | 'tradeoff';
}

interface Props {
  decisions: DecisionItem[];
  title?: string;
  intro?: string;
}

const { decisions, title = 'Decision log', intro } = Astro.props;

const outcomeLabels: Record<string, string> = {
  positive: 'Positive result',
  neutral:  'Neutral',
  tradeoff: 'Trade-off',
};
---

<section class="proj-dlog">
  <h2 class="proj-dlog-title">{title}</h2>
  {intro && <p class="proj-dlog-intro">{intro}</p>}
  <ol class="proj-dlog-list">
    {decisions.map((d, i) => {
      const type = d.outcomeType ?? 'neutral';
      return (
        <li class="proj-dlog-item">
          <span class="proj-dlog-num" aria-hidden="true">{i + 1}</span>
          <div class="proj-dlog-content">
            <h3 class="proj-dlog-decision" set:html={jargonify(d.decision)} />
            <p class="proj-dlog-rationale">{d.rationale}</p>
            <div class:list={['proj-dlog-outcome', `proj-dlog-outcome-${type}`]}>
              <span class="proj-dlog-outcome-label">{outcomeLabels[type]}</span>
              <p class="proj-dlog-outcome-text">{d.outcome}</p>
            </div>
          </div>
        </li>
      );
    })}
  </ol>
</section>

<style>
  .proj-dlog {
    padding: 0 3rem 3rem;
  }

  .proj-dlog-title {
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .proj-dlog-intro {
    margin-bottom: 1.5rem;
    max-width: 720px;
  }

  .proj-dlog-list {
    list-style: none;
    margin: 0;
    padding: 0;
    margin-top: 1.5rem;
  }

  .proj-dlog-item {
    display: grid;
    grid-template-columns: 2.75rem 1fr;
    gap: 0 0.5rem;
    padding: 2.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .proj-dlog-item:first-child {
    padding-top: 0;
  }

  .proj-dlog-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .proj-dlog-num {
    font-family: var(--mono);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--dim);
    line-height: 1;
    padding-top: 0.2em;
    text-align: right;
    user-select: none;
  }

  .proj-dlog-content {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .proj-dlog-decision {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .proj-dlog-rationale {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--sub);
    max-width: 62ch;
    margin: 0;
  }

  .proj-dlog-outcome {
    margin-top: 0.375rem;
    padding: 0.75rem 1rem;
    border-left: 3px solid;
    border-radius: 0 4px 4px 0;
  }

  .proj-dlog-outcome-positive {
    border-left-color: #1e9e61;
    background: rgba(30, 158, 97, 0.07);
  }

  .proj-dlog-outcome-neutral {
    border-left-color: var(--lime);
    background: var(--lime-dim);
  }

  .proj-dlog-outcome-tradeoff {
    border-left-color: #d97706;
    background: rgba(217, 119, 6, 0.07);
  }

  .proj-dlog-outcome-label {
    display: block;
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }

  .proj-dlog-outcome-positive .proj-dlog-outcome-label { color: #1e9e61; }
  .proj-dlog-outcome-neutral  .proj-dlog-outcome-label { color: var(--lime); }
  .proj-dlog-outcome-tradeoff .proj-dlog-outcome-label { color: #d97706; }

  .proj-dlog-outcome-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text);
    margin: 0;
  }

  @media (max-width: 860px) {
    .proj-dlog {
      padding: 0 1.25rem 2rem;
    }

    .proj-dlog-item {
      grid-template-columns: 2rem 1fr;
      gap: 0 0.375rem;
      padding: 1.75rem 0;
    }

    .proj-dlog-num {
      font-size: 1.125rem;
    }
  }
</style>
