---
interface ProcessStep {
  title: string;
  body: string;
}

interface Props {
  title: string;
  steps: ProcessStep[];
}

const { title, steps } = Astro.props;
---

<section class="proj-steps">
  <h2 class="proj-steps-title">{title}</h2>
  <div class="proj-steps-list">
    {steps.map((step, i) => (
      <div class="proj-steps-card">
        <span class="proj-steps-num">{i + 1}</span>
        <div class="proj-steps-body">
          <h3 class="proj-steps-step-title">{step.title}</h3>
          <p class="proj-steps-step-body">{step.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .proj-steps {
    padding: 0 3rem 3rem;
  }

  .proj-steps-title {
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .proj-steps-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .proj-steps-card {
    display: flex;
    gap: 1rem;
    border: 1px solid var(--border-hi);
    border-radius: 6px;
    padding: 1.25rem;
    background: var(--bg1);
  }

  .proj-steps-num {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--lime-dim);
    color: var(--lime);
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.9375rem;
  }

  .proj-steps-step-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .proj-steps-step-body {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.65;
  }

  @media (max-width: 860px) {
    .proj-steps { padding: 0 1.25rem 2rem; }
    .proj-steps-list { grid-template-columns: 1fr; }
    .proj-steps-card { padding: 1rem; }
  }
</style>
