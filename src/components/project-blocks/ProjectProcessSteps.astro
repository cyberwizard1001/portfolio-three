---
interface ProcessStep {
  title: string;
  body: string;
}

interface Props {
  title: string;
  steps: ProcessStep[];
}

const { title, steps } = Astro.props;
---

<section class="proj-steps proj-section">
  <h2 class="proj-steps-title section-title">{title}</h2>
  <div class="proj-steps-list">
    {steps.map((step, i) => (
      <div class="proj-steps-card">
        <span class="proj-steps-num">{i + 1}</span>
        <div class="proj-steps-body">
          <h3 class="proj-steps-step-title">{step.title}</h3>
          <p class="proj-steps-step-body">{step.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .proj-steps-title {
    margin-bottom: 1.5rem;
  }

  .proj-steps-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 3rem;
    align-items: start;
  }

  .proj-steps-card {
    display: flex;
    gap: 1.25rem;
    border-top: 1px solid var(--border-hi);
    padding: 1.5rem 0;
  }

  .proj-steps-num {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--lime-dim);
    color: var(--lime);
    font-family: var(--mono);
    font-weight: 700;
    font-size: 1rem;
  }

  .proj-steps-step-title {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg0);
    margin-bottom: 0.625rem;
  }

  .proj-steps-step-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--fg2);
  }

  @media (max-width: 860px) {
    .proj-steps-list { grid-template-columns: 1fr; column-gap: 0; }
  }
</style>
