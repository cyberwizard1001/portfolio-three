---
interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  title?: string;
  images: GalleryImage[];
  raw?: boolean;
}

const { title, images, raw = false } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="proj-gallery-grid proj-section">
  {title && <h2 class="proj-gallery-grid-title section-title">{title}</h2>}
  <div class="proj-gallery-grid-images">
    {images.map((img) => (
      <div class="proj-gallery-grid-item">
        <img src={raw ? img.src : `${base}${img.src.replace(/^\//, '')}`} alt={img.alt} />
      </div>
    ))}
  </div>
</section>

<style>
  .proj-gallery-grid-title {
    margin-bottom: 1.5rem;
  }

  .proj-gallery-grid-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .proj-gallery-grid-item {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border-hi);
    aspect-ratio: 1.8;
  }

  .proj-gallery-grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  @media (max-width: 860px) {
    .proj-gallery-grid-images { grid-template-columns: 1fr; }
  }
</style>
