---
interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  title: string;
  images: GalleryImage[];
}

const { title, images } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="proj-gallery-grid">
  <h2 class="proj-gallery-grid-title">{title}</h2>
  <div class="proj-gallery-grid-images">
    {images.map((img) => (
      <div class="proj-gallery-grid-item">
        <img src={`${base}${img.src.replace(/^\//, '')}`} alt={img.alt} />
      </div>
    ))}
  </div>
</section>

<style>
  .proj-gallery-grid {
    padding: 0 3rem 3rem;
  }

  .proj-gallery-grid-title {
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .proj-gallery-grid-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .proj-gallery-grid-item {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border-hi);
    aspect-ratio: 1.4;
  }

  .proj-gallery-grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 860px) {
    .proj-gallery-grid { padding: 0 1.25rem 2rem; }
    .proj-gallery-grid-images { grid-template-columns: 1fr; }
  }
</style>
