---
interface A11yIssue {
  issue: string;
  description: string;
  severity: 'critical' | 'serious' | 'moderate' | 'minor';
  wcagCriterion?: string;
  fix?: string;
}

interface Props {
  issues: A11yIssue[];
  title?: string;
  intro?: string;
}

const { issues, title = 'Accessibility audit', intro } = Astro.props;

const severityMeta: Record<string, { label: string; color: string }> = {
  critical: { label: 'Critical', color: '#dc2626' },
  serious: { label: 'Serious', color: '#d97706' },
  moderate: { label: 'Moderate', color: '#2563eb' },
  minor: { label: 'Minor', color: '#6b7280' },
};

const counts: Record<string, number> = {};
for (const issue of issues) {
  counts[issue.severity] = (counts[issue.severity] ?? 0) + 1;
}
---

<section class="proj-a11y">
  <h2 class="proj-a11y-title">{title}</h2>
  {intro && <p class="proj-a11y-intro">{intro}</p>}

  <div class="proj-a11y-summary">
    {Object.entries(counts).map(([severity, count]) => {
      const meta = severityMeta[severity];
      return (
        <span class="proj-a11y-chip" style={`--chip-color: ${meta.color}`}>
          <span class="proj-a11y-dot"></span>
          {count} {meta.label}
        </span>
      );
    })}
  </div>

  <div class="proj-a11y-table">
    {issues.map((issue) => {
      const meta = severityMeta[issue.severity];
      return (
        <div class="proj-a11y-row">
          <div class="proj-a11y-row-top">
            <span class="proj-a11y-severity" style={`--chip-color: ${meta.color}`}>{meta.label}</span>
            {issue.wcagCriterion && <span class="proj-a11y-wcag">{issue.wcagCriterion}</span>}
          </div>
          <h3 class="proj-a11y-issue">{issue.issue}</h3>
          <p class="proj-a11y-description">{issue.description}</p>
          {issue.fix && <p class="proj-a11y-fix">⚒ {issue.fix}</p>}
        </div>
      );
    })}
  </div>
</section>

<style>
  .proj-a11y {
    padding: 0 3rem 3rem;
  }

  .proj-a11y-title {
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .proj-a11y-intro {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.6;
    margin-bottom: 1rem;
    max-width: 720px;
  }

  .proj-a11y-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .proj-a11y-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--chip-color);
    background: color-mix(in srgb, var(--chip-color) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--chip-color) 22%, transparent);
    border-radius: 999px;
    padding: 6px 12px;
  }

  .proj-a11y-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--chip-color);
  }

  .proj-a11y-table {
    border: 1px solid var(--border-hi);
    border-radius: 6px;
    overflow: hidden;
  }

  .proj-a11y-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    border-bottom: 1px solid var(--border-hi);
  }

  .proj-a11y-row:last-child {
    border-bottom: none;
  }

  .proj-a11y-row-top {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .proj-a11y-severity {
    display: inline-block;
    width: fit-content;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--chip-color);
    background: color-mix(in srgb, var(--chip-color) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--chip-color) 25%, transparent);
    border-radius: 999px;
    padding: 3px 10px;
  }

  .proj-a11y-issue {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
  }

  .proj-a11y-wcag {
    font-size: 0.75rem;
    color: var(--dim);
  }

  .proj-a11y-description {
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1.6;
  }

  .proj-a11y-fix {
    font-size: 0.875rem;
    color: var(--lime);
    line-height: 1.5;
  }

  @media (max-width: 860px) {
    .proj-a11y { padding: 0 1.25rem 2rem; }
  }
</style>
