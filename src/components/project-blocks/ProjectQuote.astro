---
interface Props {
  quote: string;
  attribution?: string;
}

const { quote, attribution } = Astro.props;
---

<section class="proj-quote">
  <p class="proj-quote-text">"{quote}"</p>
  {attribution && <span class="proj-quote-attribution">{attribution}</span>}
</section>

<style>
  .proj-quote {
    padding: 0 3rem 3rem;
    max-width: 820px;
  }

  .proj-quote-text {
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: var(--text);
  }

  .proj-quote-attribution {
    display: block;
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--lime);
  }

  @media (max-width: 860px) {
    .proj-quote { padding: 0 1.25rem 2rem; }
  }
</style>
