---
interface Props {
  quote: string;
  attribution?: string;
}

const { quote, attribution } = Astro.props;
---

<section class="proj-quote proj-section">
  <p class="proj-quote-text">"{quote}"</p>
  {attribution && <span class="proj-quote-attribution eyebrow">{attribution}</span>}
</section>

<style>
  .proj-quote {
    max-width: 820px;
  }

  .proj-quote-text {
    font-size: clamp(1.375rem, 3vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: var(--text);
  }

  .proj-quote-attribution {
    display: block;
    margin-top: 1rem;
  }
</style>
