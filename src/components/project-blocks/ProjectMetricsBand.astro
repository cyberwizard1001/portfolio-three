---
interface MetricItem {
  value: string;
  label: string;
}

interface Props {
  items: MetricItem[];
}

const { items } = Astro.props;
---

<section class="proj-metrics">
  {items.map((item) => (
    <div class="proj-metrics-item">
      <span class="proj-metrics-value">{item.value}</span>
      <span class="proj-metrics-label">{item.label}</span>
    </div>
  ))}
</section>

<style>
  .proj-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    padding: 2.5rem 3rem 3rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .proj-metrics-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-left: 1.5rem;
    border-left: 1px solid var(--border);
  }

  .proj-metrics-item:first-child {
    padding-left: 0;
    border-left: none;
  }

  .proj-metrics-value {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1;
  }

  .proj-metrics-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.5;
    max-width: 220px;
  }

  @media (max-width: 1100px) {
    .proj-metrics { grid-template-columns: repeat(2, 1fr); }
    .proj-metrics-item:nth-child(2n+1) {
      padding-left: 0;
      border-left: none;
    }
    .proj-metrics-item:nth-child(n+3) {
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }
  }

  @media (max-width: 640px) {
    .proj-metrics { grid-template-columns: 1fr; gap: 1.25rem; }
    .proj-metrics-item {
      padding-left: 0;
      border-left: none;
    }
    .proj-metrics-item:not(:first-child) {
      padding-top: 1.25rem;
      border-top: 1px solid var(--border);
    }
  }

  @media (max-width: 860px) {
    .proj-metrics { padding: 0 1.25rem 2rem; }
  }
</style>
