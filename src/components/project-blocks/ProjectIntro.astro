---
interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  trailingLabel?: string;
}

const { eyebrow, title, summary, trailingLabel } = Astro.props;
---

<section class="proj-intro">
  <div class="proj-intro-top">
    <span class="proj-intro-eyebrow">{eyebrow}</span>
    {trailingLabel && <span class="proj-intro-trailing">{trailingLabel}</span>}
  </div>
  <h2 class="proj-intro-title">{title}</h2>
  <p class="proj-intro-summary">{summary}</p>
</section>

<style>
  .proj-intro {
    padding: 0 3rem 3rem;
    max-width: 1180px;
  }

  .proj-intro-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .proj-intro-eyebrow {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--lime);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .proj-intro-trailing {
    font-size: 0.8125rem;
    color: var(--dim);
  }

  .proj-intro-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .proj-intro-summary {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.7;
    max-width: 760px;
  }

  @media (max-width: 860px) {
    .proj-intro { padding: 0 1.25rem 2rem; }
    .proj-intro-top { flex-wrap: wrap; gap: 0.5rem; }
  }
</style>
