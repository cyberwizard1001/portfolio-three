---
interface Props {
  eyebrow: string;
  title: string;
  summary: string | string[];
  trailingLabel?: string;
}

const { eyebrow, title, summary, trailingLabel } = Astro.props;
const paragraphs = Array.isArray(summary) ? summary : [summary];
---

<section class="proj-intro proj-section">
  <div class="proj-intro-top">
    <span class="proj-intro-eyebrow eyebrow">{eyebrow}</span>
    {trailingLabel && <span class="proj-intro-trailing">{trailingLabel}</span>}
  </div>
  <h2 class="proj-intro-title">{title}</h2>
  {paragraphs.map((p) => <p class="proj-intro-summary">{p}</p>)}
</section>

<style>
  .proj-intro {
    max-width: 1180px;
  }

  .proj-intro-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .proj-intro-eyebrow {
    display: inline-flex;
    align-items: center;
    padding-left: 0.75rem;
    border-left: 2px solid var(--lime);
  }

  .proj-intro-trailing {
    font-size: 0.8125rem;
    color: var(--dim);
  }

  .proj-intro-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .proj-intro-summary {
    max-width: 760px;
  }

  .proj-intro-summary + .proj-intro-summary {
    margin-top: 1.25em;
  }

  @media (max-width: 860px) {
    .proj-intro-top { flex-wrap: wrap; gap: 0.5rem; }
  }
</style>
