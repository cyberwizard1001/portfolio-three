---
interface Props {
  title: string;
  points: string[];
}

const { title, points } = Astro.props;
---

<section class="proj-learnings">
  <h2 class="proj-learnings-title section-title">{title}</h2>
  <ul class="proj-learnings-list">
    {points.map((point) => (
      <li class="proj-learnings-item">
        <span class="proj-learnings-dot"></span>
        <span>{point}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .proj-learnings {
    padding: 2.5rem 3rem 3rem;
    max-width: 760px;
  }

  .proj-learnings-title {
    margin-bottom: 1.5rem;
  }

  .proj-learnings-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    list-style: none;
  }

  .proj-learnings-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .proj-learnings-dot {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--lime);
    margin-top: 0.5em;
  }

  @media (max-width: 860px) {
    .proj-learnings { padding: 2rem 1.25rem 2rem; }
  }
</style>
