---
interface Props {
  name: string;
  role: string;
  quote: string;
  goals: string[];
  frustrations: string[];
  eyebrow?: string;
  context?: string;
  contextTags?: string[];
}

const {
  name,
  role,
  quote,
  goals,
  frustrations,
  eyebrow = 'User persona',
  context,
  contextTags = [],
} = Astro.props;

const initial = name.length > 0 ? name[0].toUpperCase() : '?';
const cleanQuote = quote.trim().replace(/^["“]+/, '').replace(/["”]+$/, '');
---

<section class="proj-persona">
  <span class="proj-persona-eyebrow">{eyebrow}</span>

  <div class="proj-persona-card">
    <aside class="proj-persona-side">
      <div class="proj-persona-avatar">{initial}</div>
      <h3 class="proj-persona-name">{name}</h3>
      <span class="proj-persona-role">{role}</span>

      <div class="proj-persona-quote">
        <span class="proj-persona-quote-mark" aria-hidden="true">&ldquo;</span>
        <p>{cleanQuote}</p>
      </div>

      {contextTags.length > 0 && (
        <div class="proj-persona-tags">
          {contextTags.map((tag) => <span class="proj-persona-tag">{tag}</span>)}
        </div>
      )}
    </aside>

    <div class="proj-persona-main">
      <div class="proj-persona-lists">
        <div class="proj-persona-list proj-persona-list-goals">
          <span class="proj-persona-list-label">Goals</span>
          <ul>
            {goals.map((g) => (
              <li>
                <span class="proj-persona-icon proj-persona-icon-goal" aria-hidden="true">+</span>
                <span>{g}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="proj-persona-list proj-persona-list-frustrations">
          <span class="proj-persona-list-label">Frustrations</span>
          <ul>
            {frustrations.map((f) => (
              <li>
                <span class="proj-persona-icon proj-persona-icon-frustration" aria-hidden="true">&minus;</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      {context && (
        <div class="proj-persona-context">
          <span class="proj-persona-context-label">Why she matters</span>
          <p class="proj-persona-context-body">{context}</p>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .proj-persona {
    padding: 0 3rem 3rem;
  }

  .proj-persona-eyebrow {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--lime);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .proj-persona-card {
    display: grid;
    grid-template-columns: 260px 1fr;
    border: 1px solid var(--border-hi);
    border-radius: 6px;
    overflow: hidden;
  }

  /* ── Sidebar: who ── */
  .proj-persona-side {
    padding: 2.25rem 1.75rem;
    background: var(--bg1);
    border-right: 1px solid var(--border-hi);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .proj-persona-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(158,255,87,0.12);
    border: 2px solid rgba(158,255,87,0.3);
    color: var(--lime);
    font-size: 1.5rem;
    font-weight: 600;
    font-family: var(--mono);
    margin-bottom: 1.25rem;
  }

  .proj-persona-name {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .proj-persona-role {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.5;
    margin-top: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .proj-persona-quote {
    position: relative;
    padding: 0.5rem 0 0 1.25rem;
    border-left: 2px solid var(--lime);
  }

  .proj-persona-quote-mark {
    position: absolute;
    top: -0.6rem;
    left: 0.6rem;
    font-family: var(--sans);
    font-size: 2.5rem;
    line-height: 1;
    color: var(--lime);
    opacity: 0.6;
  }

  .proj-persona-quote p {
    font-size: 1.1875rem;
    font-weight: 500;
    font-style: italic;
    color: var(--text);
    line-height: 1.5;
    letter-spacing: -0.01em;
  }

  .proj-persona-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }

  .proj-persona-tag {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--sub);
    border: 1px solid var(--border-hi);
    border-radius: 999px;
    padding: 4px 11px;
  }

  /* ── Main: what + why ── */
  .proj-persona-main {
    display: flex;
    flex-direction: column;
  }

  .proj-persona-lists {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .proj-persona-list {
    padding: 2rem 1.75rem;
  }

  .proj-persona-list-goals {
    border-right: 1px solid var(--border);
  }

  .proj-persona-list-label {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .proj-persona-list-goals .proj-persona-list-label {
    color: var(--lime);
  }

  .proj-persona-list-frustrations .proj-persona-list-label {
    color: #ff8a7a;
  }

  .proj-persona-list ul {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
    list-style: none;
  }

  .proj-persona-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--text);
    line-height: 1.55;
  }

  .proj-persona-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    margin-top: 0.05em;
    border-radius: 4px;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 13px;
    line-height: 1;
  }

  .proj-persona-icon-goal {
    color: var(--lime);
    background: var(--lime-dim);
    border: 1px solid rgba(158,255,87,0.25);
  }

  .proj-persona-icon-frustration {
    color: #ff8a7a;
    background: rgba(255,138,122,0.10);
    border: 1px solid rgba(255,138,122,0.25);
  }

  /* ── Context ── */
  .proj-persona-context {
    padding: 1.75rem 1.75rem 2rem;
    border-top: 1px solid var(--border);
  }

  .proj-persona-context-label {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lime);
    margin-bottom: 0.75rem;
  }

  .proj-persona-context-body {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.7;
    max-width: 70ch;
  }

  @media (max-width: 860px) {
    .proj-persona { padding: 0 1.25rem 2rem; }
    .proj-persona-card { grid-template-columns: 1fr; }
    .proj-persona-side {
      border-right: none;
      border-bottom: 1px solid var(--border-hi);
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.75rem 1rem;
    }
    .proj-persona-avatar { margin-bottom: 0; }
    .proj-persona-role { margin-bottom: 0; flex-basis: 100%; }
    .proj-persona-quote { flex-basis: 100%; margin-top: 0.5rem; }
    .proj-persona-tags { flex-basis: 100%; margin-top: 0.5rem; }
    .proj-persona-lists { grid-template-columns: 1fr; }
    .proj-persona-list-goals { border-right: none; border-bottom: 1px solid var(--border); }
  }
</style>
