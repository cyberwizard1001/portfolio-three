---
interface Props {
  image: string;
  imageAlt: string;
  raw?: boolean;
  contain?: boolean;
}

const { image, imageAlt, raw = false, contain = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const src = raw ? image : `${base}${image.replace(/^\//, '')}`;
---

<section class="proj-gallery">
  <div class:list={['proj-gallery-frame', { 'proj-gallery-frame-contain': contain }]}>
    <img src={src} alt={imageAlt} class="proj-gallery-img" />
  </div>
</section>

<style>
  .proj-gallery {
    padding: 0 3rem 3rem;
  }

  .proj-gallery-frame {
    border: 1px solid var(--border-hi);
    border-radius: 6px;
    overflow: hidden;
  }

  .proj-gallery-img {
    width: 100%;
    display: block;
  }

  .proj-gallery-frame-contain {
    max-height: 640px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    background: var(--term-bg);
  }

  .proj-gallery-frame-contain .proj-gallery-img {
    width: auto;
    max-width: 100%;
    height: 640px;
    object-fit: cover;
    object-position: top;
  }

  @media (max-width: 860px) {
    .proj-gallery { padding: 0 1.25rem 2rem; }
  }
</style>
