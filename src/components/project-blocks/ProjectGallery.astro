---
interface Props {
  image: string;
  imageAlt: string;
  raw?: boolean;
  contain?: boolean;
}

const { image, imageAlt, raw = false, contain = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const src = raw ? image : `${base}${image.replace(/^\//, '')}`;
---

<section class="proj-gallery">
  <div class="proj-gallery-panel">
    <div class:list={['proj-gallery-frame', { 'proj-gallery-frame-contain': contain }]}>
      <img src={src} alt={imageAlt} class="proj-gallery-img" />
    </div>
  </div>
  <div class="proj-gallery-base"></div>
  <p class="proj-gallery-caption">{imageAlt}</p>
</section>

<style>
  .proj-gallery {
    padding: 0 3rem 3rem;
  }

  .proj-gallery-panel {
    background: var(--bg0);
    border: 1px solid var(--border-hi);
    border-radius: 16px;
    padding: 1.1rem 0.625rem 0.625rem;
    position: relative;
  }

  .proj-gallery-panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 28px;
    height: 7px;
    background: var(--bg);
    border-radius: 0 0 6px 6px;
    box-shadow: inset 0 -1px 0 var(--border-hi);
  }

  .proj-gallery-panel::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--border-hi);
    box-shadow: 0 0 0 1px var(--bg);
  }

  .proj-gallery-base {
    width: 42%;
    max-width: 200px;
    height: 9px;
    margin: 3px auto 0;
    background: linear-gradient(180deg, var(--bg2), var(--bg1));
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 10px 10px;
    position: relative;
    box-shadow: 0 6px 14px -10px rgba(0, 0, 0, 0.5);
  }

  .proj-gallery-base::after {
    content: '';
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 26%;
    height: 3px;
    background: var(--bg);
  }

  .proj-gallery-frame {
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 12px 32px -16px rgba(0, 0, 0, 0.5);
  }

  .proj-gallery-img {
    width: 100%;
    display: block;
  }

  .proj-gallery-caption {
    margin: 0.625rem 0.125rem 0;
    font-size: 0.6875rem;
    line-height: 1.4;
    color: var(--sub);
    opacity: 0.75;
  }

  .proj-gallery-frame-contain {
    max-height: 640px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .proj-gallery-frame-contain .proj-gallery-img {
    width: auto;
    max-width: 100%;
    height: 640px;
    object-fit: cover;
    object-position: top;
  }

  @media (max-width: 860px) {
    .proj-gallery { padding: 0 1.25rem 2rem; }
  }
</style>
