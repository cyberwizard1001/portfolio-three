---
interface Props {
  eyebrow: string;
  title: string;
  body: string;
  image: string;
  imageAlt: string;
  reverse?: boolean;
  raw?: boolean;
}

const { eyebrow, title, body, image, imageAlt, reverse = false, raw = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const src = raw ? image : `${base}${image.replace(/^\//, '')}`;
---

<section class:list={['proj-ti', { 'proj-ti-reverse': reverse }]}>
  <div class="proj-ti-textbody">
    <span class="proj-ti-eyebrow">{eyebrow}</span>
    <h2 class="proj-ti-title">{title}</h2>
    <p class="proj-ti-body" set:html={body} />
  </div>
  <div class="proj-ti-image">
    <div class="proj-ti-panel">
      <div class="proj-ti-frame">
        <img src={src} alt={imageAlt} />
      </div>
      <p class="proj-ti-caption">{imageAlt}</p>
    </div>
  </div>
</section>

<style>
  .proj-ti {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    column-gap: 2rem;
    padding: 0 3rem 5rem;
  }

  .proj-ti-eyebrow {
    display: block;
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1;
    color: var(--lime);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .proj-ti-textbody {
    grid-column: 1;
    grid-row: 1;
  }

  .proj-ti-image {
    grid-column: 2;
    grid-row: 1;
  }

  .proj-ti-reverse .proj-ti-textbody {
    grid-column: 2;
  }

  .proj-ti-reverse .proj-ti-image {
    grid-column: 1;
  }

  .proj-ti-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .proj-ti-body {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.7;
  }

  .proj-ti-body :global(a) {
    color: var(--lime);
    text-decoration: underline;
    text-decoration-color: rgba(158,255,87,0.35);
    text-underline-offset: 2px;
  }

  .proj-ti-body :global(a:hover) {
    text-decoration-color: var(--lime);
  }

  .proj-ti-panel {
    background: var(--bg0);
    border: 1px solid var(--border-hi);
    border-radius: 10px;
    padding: 0.625rem;
  }

  .proj-ti-frame {
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 12px 32px -16px rgba(0, 0, 0, 0.5);
  }

  .proj-ti-image img {
    width: 100%;
    display: block;
  }

  .proj-ti-caption {
    margin: 0.5rem 0.125rem 0;
    font-size: 0.6875rem;
    line-height: 1.4;
    color: var(--sub);
    opacity: 0.75;
  }

  @media (max-width: 860px) {
    .proj-ti {
      grid-template-columns: 1fr;
      padding: 0 1.25rem 3rem;
      row-gap: 1.5rem;
    }
    .proj-ti-textbody,
    .proj-ti-image,
    .proj-ti-reverse .proj-ti-textbody,
    .proj-ti-reverse .proj-ti-image {
      grid-column: 1;
      grid-row: auto;
    }
    .proj-ti-textbody {
      order: 1;
    }
    .proj-ti-image {
      order: 2;
    }
  }
</style>
