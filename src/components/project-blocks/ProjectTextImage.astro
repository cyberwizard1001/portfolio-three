---
interface Props {
  eyebrow: string;
  title: string;
  body: string;
  image: string;
  imageAlt: string;
  reverse?: boolean;
  raw?: boolean;
}

const { eyebrow, title, body, image, imageAlt, reverse = false, raw = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const src = raw ? image : `${base}${image.replace(/^\//, '')}`;
---

<section class:list={['proj-ti', { 'proj-ti-reverse': reverse }]}>
  <div class="proj-ti-text">
    <span class="proj-ti-eyebrow">{eyebrow}</span>
    <h2 class="proj-ti-title">{title}</h2>
    <p class="proj-ti-body" set:html={body} />
  </div>
  <div class="proj-ti-image">
    <img src={src} alt={imageAlt} />
  </div>
</section>

<style>
  .proj-ti {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
    padding: 0 3rem 3rem;
  }

  .proj-ti-reverse {
    direction: rtl;
  }

  .proj-ti-reverse > * {
    direction: ltr;
  }

  .proj-ti-eyebrow {
    display: block;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--lime);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .proj-ti-title {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .proj-ti-body {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--sub);
    line-height: 1.7;
  }

  .proj-ti-body :global(a) {
    color: var(--lime);
    text-decoration: underline;
    text-decoration-color: rgba(158,255,87,0.35);
    text-underline-offset: 2px;
  }

  .proj-ti-body :global(a:hover) {
    text-decoration-color: var(--lime);
  }

  .proj-ti-image img {
    width: 100%;
    border: 1px solid var(--border-hi);
    border-radius: 6px;
    display: block;
  }

  @media (max-width: 860px) {
    .proj-ti {
      grid-template-columns: 1fr;
      direction: ltr;
      padding: 0 1.25rem 2rem;
      gap: 1.5rem;
    }
    .proj-ti-reverse {
      display: flex;
      flex-direction: column-reverse;
    }
  }
</style>
