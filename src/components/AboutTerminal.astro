---
import WindowChrome from './WindowChrome.astro';
const base = import.meta.env.BASE_URL;
---

<section class="about-section grid-bg" id="about">
  <div class="term-window">
    <WindowChrome title="~/about_me — bash">
      <div class="term-body">
        <div class="term-left">
          <pre class="term-ascii" aria-hidden="true"> _  _ ___ ___ __  __   _   _
| \| |_ _| _ \  \/  | /_\ | |
| .` || ||   / |\/| |/ _ \| |__
|_|\_|___|_|_\_|  |_/_/ \_\____|

 _  __   _   ___ _____ _  _ ___ _  _______   ___   _  _
| |/ /  /_\ | _ \_   _| || |_ _| |/ / __\ \ / /_\ | \| |
| ' &lt;  / _ \|   / | | | __ || || ' &lt;| _| \ V / _ \| .` |
|_|\_\/_/ \_\_|_\ |_| |_||_|___|_|\_\___| |_/_/ \_\_|\_|</pre>
          <pre class="term-ascii term-tux" aria-hidden="true">
      .--.
     |o_o |
     |:_/ |
    //   \ \
   (|     | )
  /'\_   _/`\
  \___)=(___/</pre>
        </div>
        <div class="term-right">
          <div id="term-output-area" aria-live="polite"></div>
          <div class="term-btns">
            <a href={`${base}Resume.pdf`} target="_blank" rel="noopener" class="term-btn-p">&#8595; View CV</a>
            <a href="https://linkedin.com/in/nirmal-karthikeyan" target="_blank" rel="noopener" class="term-btn-s">LinkedIn &#8599;</a>
          </div>
        </div>
      </div>
    </WindowChrome>
  </div>
</section>

<style>
  .about-section { padding: 0 3rem 4rem; position: relative; z-index: 1; }

  .term-window {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border-hi);
    max-width: 1320px;
    margin: 0 auto;
  }

  .term-body {
    display: grid;
    grid-template-columns: 360px 1fr;
    background: var(--bg1);
    min-height: 360px;
  }

  .term-left {
    border-right: 1px solid var(--border);
    padding: 2rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    overflow: hidden;
  }

  .term-ascii {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--lime);
    line-height: 1.45;
    white-space: pre;
    opacity: 0.80;
  }

  .term-tux {
    font-size: 13px;
    line-height: 1.3;
    margin-top: 0.75rem;
  }

  .term-right {
    padding: 1.75rem 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  #term-output-area {
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.75;
    flex: 1;
    position: relative;
    max-height: 360px;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  :global(.tl-cmd) { color: var(--lime); }
  :global(.tl-ps)  { color: rgba(158,255,87,0.45); margin-right: 0.5em; }
  :global(.tl-out) { color: var(--sub); padding-left: 0; white-space: pre-wrap; }
  :global(.tl-err) { color: #ff6b6b; }

  :global(.tl-line) { display: flex; align-items: baseline; }

  :global(.term-input) {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--lime);
    caret-color: var(--lime);
    padding: 0;
    margin-right: 0.75rem;
  }

  :global(.term-input:focus-visible) {
    outline: 1px solid var(--lime);
    outline-offset: 2px;
    margin-right: 0.75rem;
    min-width: 0;
  }

  :global(.term-input::placeholder) {
    color: var(--sub);
    opacity: 0.55;
  }

  .matrix-overlay {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 2;
    background: var(--bg);
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.1;
  }

  .matrix-col {
    position: absolute;
    top: -100%;
    color: var(--lime);
    white-space: pre;
    animation: matrix-fall linear infinite;
  }

  @keyframes matrix-fall {
    from { transform: translateY(0); }
    to { transform: translateY(200%); }
  }

  .term-btns {
    display: flex;
    gap: 10px;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .term-btn-p,
  .term-btn-s {
    font-family: var(--mono);
    font-size: 12px;
    padding: 4px 14px;
    border-radius: 2px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: opacity 0.15s;
  }

  .term-btn-p { background: var(--lime); color: var(--bg); font-weight: 600; }
  .term-btn-s { background: var(--lime-dim); color: var(--lime); border: 1px solid color-mix(in srgb, var(--lime) 25%, transparent); }
  .term-btn-p:hover, .term-btn-s:hover { opacity: 0.75; }

  @media (max-width: 860px) {
    .about-section { padding: 0 1.25rem 2rem; }
    .term-body { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .about-section { padding: 0 0.75rem 1.5rem; }
    .term-left,
    .term-right { padding: 1.25rem 1rem; }
    .term-ascii { font-size: 6px; }
    .term-tux { font-size: 12px; }
  }
</style>

<script>
  (function () {
    type Line =
      | { type: 'cmd'; text: string }
      | { type: 'out'; rows: string[] }
      | { type: 'blank' }
      | { type: 'prompt' };

    const lines: Line[] = [
      { type: 'cmd', text: 'about --nirmal' },
      {
        type: 'out',
        rows: [
          'CS grad who moved from building software to designing it.',
          'I still write Flutter when the occasion calls for it. Tinkering with Linux',
          'desktop environments as a teenager is probably where the design obsession',
          "started, though I wouldn't have called it that at the time.",
        ],
      },
      { type: 'blank' },
      { type: 'cmd', text: 'skills --list' },
      {
        type: 'out',
        rows: ['UX research  ·  UX design', 'Flutter developer  ·  Linux enthusiast'],
      },
      { type: 'blank' },
      { type: 'cmd', text: 'contact --open' },
      { type: 'out', rows: ['Opening links panel…  ✓  Ready.'] },
      { type: 'blank' },
      { type: 'out', rows: ["This terminal is live — type 'help' and hit enter to try it."] },
      { type: 'blank' },
      { type: 'prompt' },
    ];

    const area = document.getElementById('term-output-area');
    let started = false;

    function scrollToBottom() {
      if (area) area.scrollTop = area.scrollHeight;
    }

    function typeChars(el: HTMLElement, text: string, speed: number, cb?: () => void) {
      let i = 0;
      (function tick() {
        if (i < text.length) {
          el.textContent += text[i++];
          scrollToBottom();
          setTimeout(tick, speed);
        } else if (cb) cb();
      })();
    }

    function runLines(idx: number) {
      if (!area || idx >= lines.length) return;
      const l = lines[idx];

      if (l.type === 'blank') {
        const el = document.createElement('div');
        el.style.height = '0.55em';
        area.appendChild(el);
        scrollToBottom();
        runLines(idx + 1);
      } else if (l.type === 'prompt') {
        enableInput();
      } else if (l.type === 'cmd') {
        const el = document.createElement('div');
        el.className = 'tl-cmd';
        el.innerHTML = '<span class="tl-ps">~$</span>';
        const cmd = document.createElement('span');
        el.appendChild(cmd);
        area.appendChild(el);
        typeChars(cmd, l.text, 38, () => setTimeout(() => runLines(idx + 1), 180));
      } else if (l.type === 'out') {
        let ri = 0;
        (function nextRow() {
          if (ri >= l.rows.length) {
            setTimeout(() => runLines(idx + 1), 90);
            return;
          }
          const el = document.createElement('div');
          el.className = 'tl-out';
          area.appendChild(el);
          typeChars(el, l.rows[ri++], 11, nextRow);
        })();
      }
    }

    function renderInstant() {
      if (!area) return;
      for (const l of lines) {
        if (l.type === 'blank') {
          const el = document.createElement('div');
          el.style.height = '0.55em';
          area.appendChild(el);
        } else if (l.type === 'prompt') {
          enableInput();
        } else if (l.type === 'cmd') {
          const el = document.createElement('div');
          el.className = 'tl-cmd';
          el.innerHTML = `<span class="tl-ps">~$</span><span>${l.text}</span>`;
          area.appendChild(el);
        } else if (l.type === 'out') {
          for (const row of l.rows) {
            const el = document.createElement('div');
            el.className = 'tl-out';
            el.textContent = row;
            area.appendChild(el);
          }
        }
      }
      scrollToBottom();
    }

    const COWSAY_TPL = (msg: string) => {
      const width = Math.min(Math.max(msg.length, 4), 40);
      const wrapped = msg.length > width ? msg.slice(0, width - 1) + '…' : msg;
      const top = ' ' + '_'.repeat(wrapped.length + 2);
      const bottom = ' ' + '-'.repeat(wrapped.length + 2);
      return [top, `< ${wrapped} >`, bottom, '        \\   ^__^', '         \\  (oo)\\_______', '            (__)\\       )\\/\\', "                ||----w |", "                ||     ||"];
    };

    const FORTUNES = [
      'There are only two hard things in CS: cache invalidation, naming things, and off-by-one errors.',
      'A UX designer walks into a bar. The bar has terrible affordances.',
      'You will fix the bug. The bug will fix you back.',
      '99 little bugs in the code, 99 little bugs... take one down, deploy to prod, 127 little bugs in the code.',
      'Tip: have you tried turning it off and on again?',
      'Design tip: if in doubt, add more whitespace.',
      'Linux tip: tab completion saves keystrokes.',
    ];

    const THEME_NAMES: Record<number, string> = {
      1: '1: default',
      2: '2: nord',
      3: '3: gruvbox',
      4: '4: dracula',
      5: '5: high contrast',
    };

    function setTheme(n: string) {
      const num = parseInt(n, 10);
      if (![1, 2, 3, 4, 5].includes(num)) return [`theme: invalid theme '${n}', try 1-5`];
      document.documentElement.setAttribute('data-theme', String(num));
      localStorage.setItem('theme', String(num));
      return [`theme set to ${THEME_NAMES[num]}`];
    }

    const WHOAMI_ADJ = ['enthusiastic', 'caffeinated', 'curious', 'overworked', 'sleep-deprived', 'pixel-obsessed', 'terminally-online', 'mildly chaotic', 'suspiciously focused'];
    const WHOAMI_ROLE = ['UX designer', 'Flutter dev', 'linux tinkerer', 'bug whisperer', 'design nerd', 'CS grad'];

    function whoami(): string[] {
      const adj = WHOAMI_ADJ[Math.floor(Math.random() * WHOAMI_ADJ.length)];
      const role = WHOAMI_ROLE[Math.floor(Math.random() * WHOAMI_ROLE.length)];
      fetch('https://api.ipify.org?format=json')
        .then((r) => r.json())
        .then((d) => appendOut([
          `${adj} ${role} @ ${d.ip}`,
          '(yes, that\'s your IP — any site you visit can see it, nothing special here)',
        ]))
        .catch(() => appendOut([`${adj} ${role} @ 0.0.0.0`, '(could not look up your IP, but sites normally can)']));
      return ['looking up who you are...'];
    }

    function neofetch(): string[] {
      const theme = document.documentElement.getAttribute('data-theme') || '1';
      const mode = document.documentElement.getAttribute('data-mode') || 'dark';
      return [
        'nirmal@dev',
        '------------',
        'OS: Linux',
        'Shell: zsh',
        'Editor: neovim',
        `Theme: ${THEME_NAMES[parseInt(theme, 10)] || theme} (${mode})`,
        'Role: UX design -> Flutter dev',
        'Uptime: still tinkering',
      ];
    }

    function runMatrix() {
      const wrap = area?.parentElement;
      if (!wrap) return ['matrix: nothing to render on'];
      const overlay = document.createElement('div');
      overlay.className = 'matrix-overlay';
      const cols = Math.floor(wrap.clientWidth / 14);
      const chars = 'アイウエオカキクケコ01';
      for (let i = 0; i < cols; i++) {
        const col = document.createElement('div');
        col.className = 'matrix-col';
        col.style.left = `${i * 14}px`;
        col.style.animationDuration = `${1 + Math.random() * 1.5}s`;
        col.style.animationDelay = `-${Math.random() * 2}s`;
        let text = '';
        for (let j = 0; j < 30; j++) text += chars[Math.floor(Math.random() * chars.length)] + '\n';
        col.textContent = text;
        overlay.appendChild(col);
      }
      wrap.appendChild(overlay);
      setTimeout(() => overlay.remove(), 4000);
      return [];
    }

    type Cmd = { desc: string; run: (args: string) => string[] };

    const COMMANDS: Record<string, Cmd> = {
      help: { desc: 'list available commands', run: () => Object.entries(COMMANDS).map(([name, c]) => `${name.padEnd(10)} ${c.desc}`) },
      about: { desc: 'about nirmal', run: () => ['CS grad who moved from building software to designing it.', 'I still write Flutter when the occasion calls for it. Tinkering with Linux', 'desktop environments as a teenager is probably where the design obsession', "started, though I wouldn't have called it that at the time."] },
      skills: { desc: 'list skills', run: () => ['UX research  ·  UX design', 'Flutter developer  ·  Linux enthusiast'] },
      contact: { desc: 'show contact links', run: () => ['github:   github.com/cyberwizard1001', 'linkedin: linkedin.com/in/nirmal-karthikeyan', 'Opening links panel…  ✓  Ready.'] },
      whoami: { desc: 'who is using this terminal', run: whoami },
      ls: { desc: 'list site sections', run: () => ['about.md', 'work/', 'contact.txt', '(scroll the page to explore each section)'] },
      neofetch: { desc: 'show system info (sort of)', run: neofetch },
      cowsay: { desc: 'cowsay <message>', run: (args) => COWSAY_TPL(args || 'moo') },
      fortune: { desc: 'random one-liner', run: () => [FORTUNES[Math.floor(Math.random() * FORTUNES.length)]] },
      theme: { desc: 'theme [1-5] — list or switch theme', run: (args) => (args ? setTheme(args.trim()) : ['available themes:', ...THEME_NAMES, 'usage: theme <number>']) },
      matrix: { desc: 'wake up, neo', run: runMatrix },
      sudo: { desc: 'sudo <cmd>', run: () => ['Permission denied: nice try.'] },
      clear: { desc: 'clear the terminal', run: () => [] },
      reset: { desc: 'reset the terminal to its initial state', run: () => [] },
      history: { desc: 'show command history', run: () => (cmdHistory.length ? cmdHistory.map((h, i) => `${i + 1}  ${h}`) : ['no history yet']) },
    };
    COMMANDS['?'] = COMMANDS.help;

    const cmdHistory: string[] = [];
    let historyIdx = -1;

    function appendOut(rows: string[]) {
      if (!area) return;
      const activeLine = area.querySelector('.tl-line');
      for (const row of rows) {
        const el = document.createElement('div');
        el.className = 'tl-out';
        el.textContent = row;
        if (activeLine) area.insertBefore(el, activeLine);
        else area.appendChild(el);
      }
      scrollToBottom();
    }

    function executeCommand(raw: string) {
      const trimmed = raw.trim();
      if (!trimmed) return true;
      cmdHistory.push(trimmed);
      historyIdx = cmdHistory.length;

      const spaceIdx = trimmed.indexOf(' ');
      const cmd = (spaceIdx === -1 ? trimmed : trimmed.slice(0, spaceIdx)).toLowerCase();
      const args = spaceIdx === -1 ? '' : trimmed.slice(spaceIdx + 1).trim();

      if (cmd === 'clear') {
        if (area) area.innerHTML = '';
        return true;
      }

      if (cmd === 'reset') {
        if (area) area.innerHTML = '';
        cmdHistory.length = 0;
        historyIdx = -1;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || window.matchMedia('(max-width: 860px)').matches) {
          renderInstant();
        } else {
          runLines(0);
        }
        return false;
      }

      const command = COMMANDS[cmd];
      if (!command) {
        appendOut([`command not found: ${cmd}`, "try 'help' for a list of commands"]);
        return true;
      }
      const out = command.run(args);
      if (out.length) appendOut(out);
      return true;
    }

    function enableInput() {
      if (!area) return;
      const line = document.createElement('div');
      line.className = 'tl-cmd tl-line';
      line.innerHTML = '<span class="tl-ps">~$</span>';
      const input = document.createElement('input');
      input.className = 'term-input';
      input.autocomplete = 'off';
      input.spellcheck = false;
      input.placeholder = 'type a command…';
      input.setAttribute('aria-label', 'Terminal command input');
      line.appendChild(input);
      area.appendChild(line);
      input.focus({ preventScroll: true });
      scrollToBottom();

      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          const val = input.value;
          line.classList.remove('tl-line');
          const echo = document.createElement('span');
          echo.textContent = val;
          line.appendChild(input.value ? echo : document.createTextNode(''));
          input.remove();
          if (executeCommand(val)) enableInput();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (historyIdx > 0) historyIdx--;
          input.value = cmdHistory[historyIdx] ?? '';
        } else if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (historyIdx < cmdHistory.length) historyIdx++;
          input.value = cmdHistory[historyIdx] ?? '';
        }
      });

      area.parentElement?.addEventListener('click', () => input.focus({ preventScroll: true }));
    }

    function start() {
      if (started) return;
      started = true;
      // skip the typing animation for reduced-motion users and on mobile (no room to watch it play out)
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reducedMotion || window.matchMedia('(max-width: 860px)').matches) {
        renderInstant();
      } else {
        runLines(0);
      }
    }

    // don't run the animation until the terminal scrolls into view
    const obs = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          start();
          obs.disconnect();
        }
      },
      { threshold: 0.3 }
    );

    const sec = document.getElementById('about');
    if (sec) obs.observe(sec);
  })();
</script>
