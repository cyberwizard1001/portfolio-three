---
const base = import.meta.env.BASE_URL;
---

<header class="waybar">
  <div class="wb-left">
    <div class="wb-section wb-logo-sec">
      <a href={base} class="wb-logo">nirmal@karthikeyan</a>
    </div>
    <div class="wb-section">
      <div class="wb-workspaces">
        <button type="button" class="ws-pill" data-tooltip="Default" aria-label="Switch to Default theme" aria-pressed="false">1</button>
        <button type="button" class="ws-pill" data-tooltip="Nord" aria-label="Switch to Nord theme" aria-pressed="false">2</button>
        <button type="button" class="ws-pill active" data-tooltip="Gruvbox" aria-label="Switch to Gruvbox theme" aria-pressed="true">3</button>
        <button type="button" class="ws-pill" data-tooltip="Dracula" aria-label="Switch to Dracula theme" aria-pressed="false">4</button>
        <button type="button" class="ws-pill" data-tooltip="High Contrast" aria-label="Switch to High Contrast theme" aria-pressed="false">5</button>
      </div>
      <div class="theme-hint" id="theme-hint" role="status">
        <span class="theme-hint-dot">●</span>
        <span class="theme-hint-text">workspaces 1–5 are color schemes — click one</span>
        <button class="theme-hint-close" id="theme-hint-close" aria-label="Dismiss hint">×</button>
      </div>
    </div>
    <div class="wb-section wb-tagline">
      <span class="wb-label">user-centered <span class="hl">design</span></span>
    </div>
    <div class="wb-section wb-quote">
      <span class="wb-label">"Good design is invisible"</span>
    </div>
    <div class="wb-section center">
      <span class="wb-label">portfolio — <span class="hl">UX research &amp; design · Flutter</span></span>
    </div>
  </div>
  <div class="wb-section right">
    <a href={`${base}Resume.pdf`} class="wb-link" target="_blank" rel="noopener">CV</a>
    <div class="wb-sep"></div>
    <a href={`${base}contact`} class="wb-cta">contact</a>
    <div class="wb-sep"></div>
    <span class="wb-label wb-hide-md">open for collab</span>
    <div class="wb-sep wb-hide-md"></div>
    <div class="wb-feedback wb-hide-sm" id="wb-feedback">
      <span class="wb-label" id="fb-label">feedback</span>
      <div class="fb-buttons" id="fb-buttons">
        <button class="fb-btn" data-rating="good" aria-label="Good, rate this page positively" title="Good">🙂</button>
        <button class="fb-btn" data-rating="okay" aria-label="Okay, rate this page neutrally" title="Okay">😐</button>
        <button class="fb-btn" data-rating="bad" aria-label="Not great, rate this page negatively" title="Not great">🙁</button>
      </div>
    </div>
    <div class="wb-sep wb-hide-sm"></div>
    <span class="wb-clock" id="clock">--:--</span>
    <div class="wb-sep"></div>
    <button type="button" class="mode-toggle" id="mode-toggle" aria-label="Switch to light mode">☾</button>
  </div>
</header>

<div class="wb-theme-strip" role="group" aria-label="Color theme">
  <span class="wts-label">theme</span>
  <div class="wts-pills">
    <button type="button" class="ws-pill" aria-label="Switch to Default theme" aria-pressed="false">1</button>
    <button type="button" class="ws-pill" aria-label="Switch to Nord theme" aria-pressed="false">2</button>
    <button type="button" class="ws-pill" aria-label="Switch to Gruvbox theme" aria-pressed="false">3</button>
    <button type="button" class="ws-pill" aria-label="Switch to Dracula theme" aria-pressed="false">4</button>
    <button type="button" class="ws-pill" aria-label="Switch to High Contrast theme" aria-pressed="false">5</button>
  </div>
  <button type="button" class="mode-toggle" id="mode-toggle-strip" aria-label="Switch to light mode">☾</button>
</div>

<style>
  .waybar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: var(--bar-h);
    background: var(--bg0);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: stretch;
  }

  .wb-left {
    display: flex;
    align-items: stretch;
    flex: 1 1 0;
    min-width: 0;
  }

  .wb-section {
    display: flex;
    align-items: center;
    padding: 0 1rem;
    border-right: 1px solid var(--border);
    gap: 0.5rem;
  }

  .wb-section.right {
    border-right: none;
    border-left: 1px solid var(--border);
    flex-shrink: 0;
  }

  .wb-section.center {
    border-right: none;
    border-left: 1px solid var(--border);
    padding: 0 1.5rem;
  }

  .wb-workspaces { display: flex; gap: 4px; position: relative; }

  .theme-hint {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--bg2);
    border: 1px solid var(--lime);
    border-radius: 3px;
    padding: 6px 8px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text);
    white-space: nowrap;
    z-index: 150;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
    box-shadow: 0 4px 14px rgba(0,0,0,0.35);
  }

  .theme-hint::before {
    content: '';
    position: absolute;
    top: -5px;
    left: 14px;
    width: 8px;
    height: 8px;
    background: var(--bg2);
    border-left: 1px solid var(--lime);
    border-top: 1px solid var(--lime);
    transform: rotate(45deg);
  }

  .theme-hint.show {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .theme-hint-dot {
    color: var(--lime);
    font-size: 9px;
  }

  .theme-hint-close {
    background: none;
    border: none;
    color: var(--dim);
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1;
    cursor: pointer;
    padding: 0 0 0 4px;
  }

  .theme-hint-close:hover { color: var(--lime); }

  @media (max-width: 860px) {
    .theme-hint { display: none; }
  }

  .ws-pill {
    font-family: var(--mono);
    font-size: 12px;
    width: 26px;
    height: 22px;
    padding: 0;
    border-radius: 3px;
    border: 1px solid var(--border-hi);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--dim);
    cursor: pointer;
    transition: all 0.15s;
  }

  .ws-pill.active {
    background: var(--lime-dim);
    border-color: var(--lime);
    color: var(--lime);
  }

  .ws-pill:hover:not(.active) {
    border-color: var(--lime);
    color: var(--lime);
  }

  .ws-pill:active {
    transform: scale(0.92);
  }

  .ws-pill[data-tooltip] {
    position: relative;
  }

  .ws-pill[data-tooltip]::after {
    content: attr(data-tooltip);
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg2);
    border: 1px solid var(--border-hi);
    color: var(--text);
    font-size: 11px;
    font-family: var(--mono);
    white-space: nowrap;
    padding: 3px 7px;
    border-radius: 3px;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.12s, visibility 0.12s;
    z-index: 200;
  }

  .ws-pill[data-tooltip]:hover::after {
    opacity: 1;
    visibility: visible;
  }

  .wb-logo {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--lime);
    text-decoration: none;
    letter-spacing: 0.04em;
  }

  .wb-label {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--dim);
    white-space: nowrap;
  }

  .wb-link {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--dim);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .wb-link:hover {
    color: var(--lime);
  }

  .wb-cta {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--bg0);
    background: var(--lime);
    border: 1px solid var(--lime);
    border-radius: 3px;
    padding: 3px 10px;
    white-space: nowrap;
    transition: all 0.15s;
  }

  .wb-cta:hover {
    background: transparent;
    color: var(--lime);
  }

  .wb-cta:active {
    transform: scale(0.92);
  }

  .wb-label .hl { color: var(--sub); }
  .wb-label .lime { color: var(--lime); }

  .wb-feedback {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .fb-buttons {
    display: flex;
    gap: 4px;
  }

  .fb-btn {
    font-family: var(--mono);
    font-size: 12px;
    width: 22px;
    height: 22px;
    border-radius: 3px;
    border: 1px solid var(--border-hi);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.15s;
    line-height: 1;
    padding: 0;
  }

  .fb-btn:hover:not(:disabled) {
    border-color: var(--lime);
    background: var(--lime-dim);
  }

  .fb-btn:active:not(:disabled) {
    transform: scale(0.9);
  }

  .fb-btn.selected {
    border-color: var(--lime);
    background: var(--lime-dim);
  }

  .fb-btn:disabled {
    opacity: 0.4;
    cursor: default;
  }

  .wb-feedback.sent .wb-label,
  .wb-feedback.limited .wb-label {
    color: var(--lime);
  }

  .wb-feedback.limited .wb-label {
    color: var(--dim);
  }

  .wb-sep {
    width: 1px;
    height: 16px;
    background: var(--border);
    margin: 0 0.25rem;
  }

  .wb-clock {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .mode-toggle {
    font-family: var(--mono);
    font-size: 12px;
    width: 22px;
    height: 22px;
    padding: 0;
    border-radius: 3px;
    border: 1px solid var(--lime);
    background: color-mix(in srgb, var(--lime) 14%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lime);
    cursor: pointer;
    transition: all 0.15s;
    position: relative;
  }

  .mode-toggle::before {
    content: '';
    position: absolute;
    inset: -10px;
  }

  .mode-toggle:hover {
    border-color: var(--lime);
    color: var(--bg);
    background: var(--lime);
  }

  .mode-toggle:active {
    transform: scale(0.92);
  }

  @media (max-width: 1200px) {
    .wb-section.wb-quote { display: none; }
  }

  @media (max-width: 1100px) {
    .wb-section.center { display: none; }
  }

  @media (max-width: 960px) {
    .wb-section.wb-tagline { display: none; }
  }

  @media (max-width: 860px) {
    .wb-section:not(.wb-logo-sec):not(.right) { display: none; }
  }

  @media (max-width: 720px) {
    .wb-hide-md { display: none; }
  }

  @media (max-width: 600px) {
    .wb-section.right { padding: 0 0.6rem; }
    .wb-hide-sm { display: none; }
  }

  /* ── Mobile theme strip ── */
  .wb-theme-strip {
    display: none;
  }

  @media (max-width: 860px) {
    .wb-theme-strip {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      position: fixed;
      top: 42px; left: 0; right: 0;
      height: 36px;
      padding: 0 1rem;
      background: var(--bg0);
      border-bottom: 1px solid var(--border);
      z-index: 99;
    }

    .wts-label {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--dim);
      letter-spacing: 0.08em;
      margin-right: 0.25rem;
      flex-shrink: 0;
    }

    .wts-pills {
      display: flex;
      gap: 6px;
      flex: 1;
    }

    .wb-theme-strip .ws-pill {
      width: 36px;
      height: 28px;
      font-size: 13px;
      position: relative;
    }

    .wb-theme-strip .ws-pill::before {
      content: '';
      position: absolute;
      inset: -6px -3px;
    }

    .wb-theme-strip .mode-toggle {
      width: 28px;
      height: 28px;
      flex-shrink: 0;
    }
  }
</style>

<script>
  function updateClock() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    const clock = document.getElementById('clock');
    if (clock) clock.textContent = `${h}:${m}`;
  }
  updateClock();
  setInterval(updateClock, 10000);
</script>

<script>
  (function () {
    const container = document.getElementById('wb-feedback');
    const label = document.getElementById('fb-label');
    const buttons = document.querySelectorAll<HTMLButtonElement>('.fb-btn');
    if (!container || !label || buttons.length === 0) return;

    // sitewide (not per-path) so the limit applies across every page in the session.
    // This is UX only (avoids a flash of enabled buttons / a wasted round trip) —
    // sessionStorage is trivially editable via devtools, so it is NOT the security
    // boundary. The real limit (1 vote per IP per hour, sitewide) is enforced
    // server-side in worker/index.ts and cannot be bypassed from the client.
    const storageKey = 'feedbackSentThisSession';

    const showSent = (rating: string) => {
      container.classList.add('sent');
      label.textContent = 'thanks for the feedback';
      buttons.forEach((b) => {
        b.disabled = true;
        b.classList.toggle('selected', b.dataset.rating === rating);
      });
    };

    const showLimited = () => {
      container.classList.add('limited');
      label.textContent = 'already shared feedback this session';
      buttons.forEach((b) => (b.disabled = true));
    };

    if (sessionStorage.getItem(storageKey)) {
      showLimited();
      return;
    }

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const rating = button.dataset.rating ?? 'okay';
        showSent(rating);
        sessionStorage.setItem(storageKey, String(Date.now()));

        fetch('/api/feedback', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            rating,
            path: location.pathname,
            theme: document.documentElement.getAttribute('data-theme') ?? 'unknown',
          }),
        })
          .then((res) => {
            if (res.status === 429) showLimited();
          })
          .catch(() => {
            // best-effort: feedback is non-critical, fail silently
          });
      });
    });
  })();
</script>

<script>
  (function () {
    const pills = document.querySelectorAll<HTMLElement>('.ws-pill');
    const modeToggles = document.querySelectorAll<HTMLElement>('#mode-toggle, #mode-toggle-strip');
    const hint = document.getElementById('theme-hint');
    const hintClose = document.getElementById('theme-hint-close');

    const dismissHint = () => {
      hint?.classList.remove('show');
      localStorage.setItem('themeHintSeen', '1');
    };

    if (hint && !localStorage.getItem('themeHintSeen')) {
      setTimeout(() => hint.classList.add('show'), 600);
      setTimeout(dismissHint, 8000);
    }

    hintClose?.addEventListener('click', dismissHint);

    const setTheme = (theme: string) => {
      document.documentElement.setAttribute('data-theme', theme);
      pills.forEach((p) => {
        const isActive = (p.dataset.theme ?? p.textContent?.trim()) === theme;
        p.classList.toggle('active', isActive);
        p.setAttribute('aria-pressed', String(isActive));
      });
      localStorage.setItem('theme', theme);
    };

    const setMode = (mode: string) => {
      document.documentElement.setAttribute('data-mode', mode);
      modeToggles.forEach((btn) => {
        btn.textContent = mode === 'light' ? '☀' : '☾';
        btn.setAttribute('aria-label', mode === 'light' ? 'Switch to dark mode' : 'Switch to light mode');
      });
      localStorage.setItem('mode', mode);
    };

    let savedTheme = localStorage.getItem('theme');
    let savedMode = localStorage.getItem('mode');

    if (savedTheme) setTheme(savedTheme);
    setMode(savedMode === 'light' ? 'light' : 'dark');

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        setTheme(pill.dataset.theme ?? pill.textContent?.trim() ?? '1');
        dismissHint();
      });
    });

    modeToggles.forEach((btn) => {
      btn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-mode');
        setMode(current === 'light' ? 'dark' : 'light');
      });
    });
  })();
</script>
