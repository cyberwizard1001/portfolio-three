---
interface Props {
  title: string;
  description: string;
  link: string;
  tags?: string[];
  heroImage?: string;
}

const { title, description, link, tags = [], heroImage } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<a class="card-window" href={link} target="_blank" rel="noopener">
  <div class="card-bar">
    <div class="card-controls">
      <div class="card-ctrl"></div><div class="card-ctrl"></div><div class="card-ctrl"></div>
    </div>
    <span class="card-bar-title">vim: <span class="fname">{title.toLowerCase().replace(/\s+/g, '-')}</span></span>
  </div>
  {heroImage && (
    <div class="bw-hero">
      <img src={heroImage?.startsWith('/') ? `${base}${heroImage}` : heroImage} alt={`${title} preview`} class="bw-hero-img" loading="lazy"/>
    </div>
  )}
  <div class="bw-content">
    <h3 class="bw-title-text">{title}</h3>
    <p class="bw-desc">{description}</p>
    {tags.length > 0 && (
      <ul class="bw-tags">
        {tags.map((tag) => (
          <li class="bw-tag">{tag}</li>
        ))}
      </ul>
    )}
  </div>
  <div class="card-statusline">
    <span class="sl-arrow">↗</span>
  </div>
</a>

<style>
  /* Card-level chrome (bar, controls, statusline) lives in global.css as .card-window.
     These styles cover the hero image and content area unique to BuildCard. */

  .bw-hero {
    height: 210px;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    flex-shrink: 0;
    background: var(--term-bg);
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 32px 32px;
    position: relative;
  }

  .bw-hero-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top left;
    opacity: 0.9;
    mix-blend-mode: luminosity;
    transition: transform 0.4s ease;
  }

  .card-window:hover .bw-hero-img { transform: scale(1.02); }

  .bw-content {
    padding: 1.5rem 1.75rem 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .bw-title-text {
    font-family: var(--mono);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 0.6rem;
  }

  .bw-desc {
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--sub);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 0.875rem;
  }

  .bw-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .bw-tag {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--lime);
    background: var(--lime-dim);
    border: 1px solid rgba(158,255,87,0.2);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }
</style>
