---
import WindowChrome from './WindowChrome.astro';
const base = import.meta.env.BASE_URL;
---

<section class="hero-section grid-bg">
  <div class="hero-window">
    <WindowChrome title="bash —" activeTitle="~/portfolio/nirmal" icon="⌃⌥T">
      <div class="hero-win-body">
        <div class="hero-main">
          <div class="hero-copy">
            <p class="hero-prompt">
              <span class="ps1">nirmal@dev ~/portfolio $</span>&nbsp;cat about.txt<span class="cursor-blink"></span>
            </p>
            <h1 class="hero-h1">
              <span class="stroke">Less friction,</span><br />
              More clarity.<br />
              <span class="lime">Better</span><br />
              decisions.
            </h1>
          </div>
          <dl class="hero-meta">
            <div class="hm-row">
              <dt>role</dt>
              <dd>Product Designer</dd>
            </div>
            <div class="hm-row">
              <dt>focus</dt>
              <dd>Product design, research & design systems</dd>
            </div>
            <div class="hm-row">
              <dt>based</dt>
              <dd>United Kingdom (Remote-friendly)</dd>
            </div>
            <div class="hm-row">
              <dt>status</dt>
              <dd><span class="hm-dot"></span>Open for collaboration</dd>
            </div>
          </dl>
        </div>
        <div class="hero-split">
          <div class="hs-cell">
            <p class="hs-label">background</p>
            <p class="hs-text">
              Interfaces are vehicles that get users places. I care about making them easy to understand and operate. For first-time drivers and seasoned ones alike, whether they're tired, distracted, or under pressure.
            </p>
            <div class="hs-tags">
              <span class="hs-tag active">UX research</span>
              <span class="hs-tag active">design systems</span>
              <span class="hs-tag active">prototyping</span>
              <span class="hs-tag">Flutter</span>
            </div>
            <p class="hs-typewriter" aria-live="polite" aria-atomic="true">
              <span class="hs-tw-ps">~$</span>
              <span class="hs-tw-text" id="hero-typewriter"></span><span class="hs-tw-cursor"></span>
            </p>
          </div>
          <div class="hs-cell">
            <p class="hs-label">currently</p>
            <p class="hs-text">
              Designing at Tedaisy Insurance Group and volunteering at Reach Volunteering. In my free time, I work on products that are honest about what they ask of people’s time and attention (do check out Medium).
            </p>
            <div class="hs-ctas">
              <a href="#work" class="hs-cta">View my work ↓</a>
              <a href={`${base}contact`} class="hs-cta hs-cta-ghost">Contact me ↗</a>
            </div>
          </div>
        </div>
      </div>
    </WindowChrome>
  </div>
</section>

<style>
  .hero-section {
    min-height: calc(100vh - var(--bar-h));
    padding: 1.75rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }

  .hero-window {
    position: relative;
    z-index: 1;
    max-width: 1320px;
    margin: 0 auto;
    width: 100%;
  }

  .hero-win-body {
    background: var(--term-overlay);
    display: grid;
    grid-template-rows: 1fr auto;
  }

  .hero-main {
    padding: 1.75rem 2.5rem 1.5rem;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 2rem;
  }

  .hero-copy { min-width: 0; }

  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding-left: 2rem;
    border-left: 1px solid var(--border);
    margin: 0;
    min-width: 220px;
  }

  .hm-row dt {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--dim);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }

  .hm-row dd {
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--sub);
    margin: 0;
    line-height: 1.4;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .hm-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 0 3px var(--lime-dim);
  }

  @media (max-width: 1024px) {
    .hero-main {
      grid-template-columns: 1fr;
    }
    .hero-meta {
      padding-left: 0;
      border-left: none;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem 2rem;
    }
  }

  .hero-prompt {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--lime);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-prompt .ps1 { color: var(--dim); }

  .hero-h1 {
    font-family: var(--mono);
    font-size: clamp(2.75rem, 6.5vw, 6.25rem);
    font-weight: 700;
    letter-spacing: -0.045em;
    line-height: 0.9;
    color: var(--text);
    margin-bottom: 0;
  }

  .hero-h1 .stroke {
    -webkit-text-stroke: 1.5px var(--dim);
    color: transparent;
  }

  .hero-h1 .lime { color: var(--lime); }

  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--border);
  }

  .hs-cell {
    padding: 1.25rem 2rem;
    border-right: 1px solid var(--border);
  }

  .hs-cell:last-child { border-right: none; }

  .hs-label {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--dim);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .hs-text {
    font-family: var(--mono);
    font-size: 0.875rem;
    color: color-mix(in srgb, var(--text) 85%, transparent);
    line-height: 1.65;
    max-width: 380px;
  }

  .hs-tags {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    margin-top: 0.9rem;
  }

  .hs-tag {
    font-family: var(--mono);
    font-size: 12px;
    padding: 3px 9px;
    border: 1px solid var(--border-hi);
    border-radius: 2px;
    color: var(--dim);
  }

  .hs-tag.active {
    border-color: var(--lime);
    color: var(--lime);
    background: var(--lime-dim);
  }

  .hs-ctas {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .hs-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.875rem;
    font-weight: 600;
    background: var(--lime);
    color: var(--lime-contrast);
    padding: 0.55rem 1.25rem;
    text-decoration: none;
    border-radius: 2px;
    letter-spacing: -0.01em;
    transition: opacity 0.15s;
  }

  .hs-cta-ghost {
    background: transparent;
    color: var(--lime);
    border: 1px solid var(--lime);
  }

  .hs-cta:hover { opacity: 0.8; }

  .hs-typewriter {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--dim);
    margin-top: 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 1.4em;
  }

  .hs-tw-ps { color: var(--lime); flex-shrink: 0; }

  .hs-tw-cursor {
    display: inline-block;
    width: 1px;
    height: 0.9em;
    background: var(--lime);
    vertical-align: middle;
    animation: tw-blink 1s step-end infinite;
  }

  @keyframes tw-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (max-width: 860px) {
    .hero-section { padding: 1.25rem; }
    .hero-split { grid-template-columns: 1fr; }
    .hs-typewriter { display: none; }
  }

  @media (max-width: 480px) {
    .hero-h1 { font-size: clamp(2rem, 11vw, 2.75rem); }
    .hero-main { padding: 1.25rem; }
    .hero-prompt { margin-bottom: 1rem; }
    .hero-meta { gap: 1rem; }
    .hs-cell { padding: 1rem 1.25rem; }
  }
</style>

<script>
  (function () {
    const el = document.getElementById('hero-typewriter');
    if (!el) return;

    const tips = [
      'click 1–5 in the top bar to switch color schemes',
      'click ☾ top-right to toggle dark / light mode',
    ];

    let tipIdx = 0;
    let charIdx = 0;
    let deleting = false;
    let pauseTicks = 0;

    const PAUSE_AFTER_TYPE = 38;
    const PAUSE_AFTER_DELETE = 8;
    const TYPE_MS = 45;
    const DELETE_MS = 22;

    function tick() {
      const current = tips[tipIdx];

      if (pauseTicks > 0) {
        pauseTicks--;
        setTimeout(tick, deleting ? DELETE_MS : TYPE_MS);
        return;
      }

      if (!deleting) {
        charIdx++;
        el.textContent = current.slice(0, charIdx);
        if (charIdx === current.length) {
          deleting = true;
          pauseTicks = PAUSE_AFTER_TYPE;
        }
        setTimeout(tick, TYPE_MS);
      } else {
        charIdx--;
        el.textContent = current.slice(0, charIdx);
        if (charIdx === 0) {
          deleting = false;
          tipIdx = (tipIdx + 1) % tips.length;
          pauseTicks = PAUSE_AFTER_DELETE;
        }
        setTimeout(tick, DELETE_MS);
      }
    }

    setTimeout(tick, 1200);
  })();
</script>

