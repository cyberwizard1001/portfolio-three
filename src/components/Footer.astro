---
const base = import.meta.env.BASE_URL;
const projects = [
  { title: 'Pet Insurance Quote Flow', slug: 'pet-insurance-checkout' },
  { title: 'Perro Onboarding', slug: 'perro-onboarding' },
  { title: 'Crafting Counselling Companions', slug: 'counselling-companions' },
];
---

<footer class="site-footer">
  <div class="footer-body">
        <div class="footer-email-block">
          <span class="fb-ps">~$</span>
          <a href="mailto:nirmalkarthikeyan1503@gmail.com" class="fb-email">
            nirmalkarthikeyan1503@gmail.com<span class="term-cursor"></span>
          </a>
        </div>

        <div class="footer-grid">
          <div class="footer-brand">
            <h3>Nirmal Karthikeyan</h3>
            <p>UX designer focused on clear, thoughtful digital experiences across product, service, and web journeys.</p>
          </div>

          <nav class="footer-col" aria-label="Navigate">
            <h4>// navigate</h4>
            <a href={base}>Home</a>
            <a href={`${base}contact`}>Contact</a>
          </nav>

          <nav class="footer-col" aria-label="Projects">
            <h4>// projects</h4>
            {projects.map((p) => (
              <a href={`${base}projects/${p.slug}`}>{p.title}</a>
            ))}
          </nav>

          <nav class="footer-col" aria-label="Elsewhere">
            <h4>// elsewhere</h4>
            <a href="https://linkedin.com/in/nirmal-karthikeyan" target="_blank" rel="noopener">LinkedIn</a>
            <a href="https://medium.com/@nirmalkarthikeyan" target="_blank" rel="noopener">Medium</a>
            <a href={`${base}cv.pdf`} target="_blank" rel="noopener">CV</a>
            <a href="mailto:nirmalkarthikeyan1503@gmail.com">Email</a>
          </nav>
        </div>

        <div class="footer-bottom">
          <span>© 2026 Nirmal Karthikeyan</span>
          <span>Built with Astro &amp; TypeScript by Nirmal Karthikeyan.</span>
        </div>
  </div>
</footer>
