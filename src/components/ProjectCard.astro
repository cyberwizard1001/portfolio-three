---
interface StatuslineChunk {
  label: string;
  lime?: boolean;
}

interface Props {
  href: string;
  filename: string;
  image: string;
  imageAlt: string;
  type: string;
  year: string;
  title: string;
  oneliner: string;
  statusline: StatuslineChunk[];
  isNew?: boolean;
}

const { href, filename, image, imageAlt, type, year, title, oneliner, statusline, isNew } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a class="card-window proj-window" href={href}>
  <div class="card-bar">
    <div class="card-controls">
      <div class="card-ctrl"></div><div class="card-ctrl"></div><div class="card-ctrl"></div>
    </div>
    <span class="card-bar-title">vim: <span class="fname">{filename}</span></span>
    {isNew && <span class="pw-new-badge">NEW</span>}
  </div>
  <div class="pw-image">
    <img src={`${base}${image.replace(/^\//, '')}`} alt={imageAlt} class="pw-img-el" />
  </div>
  <div class="pw-content">
    <div class="pw-meta">
      <span class="pw-type">{type}</span>
      <span class="pw-year">{year}</span>
    </div>
    <h3 class="pw-title-text">{title}</h3>
    <p class="pw-oneliner">{oneliner}</p>
    {statusline.length > 0 && (
      <ul class="pw-tags">
        {statusline.map(c => (
          <li class="pw-tag">{c.label}</li>
        ))}
      </ul>
    )}
  </div>
  <div class="card-statusline">
    <span class="sl-arrow">↗</span>
  </div>
</a>

<style>
  /* Card-level chrome (bar, controls, statusline) lives in global.css as .card-window.
     These styles cover the image panel and content area unique to ProjectCard. */

  .pw-new-badge {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 2px 7px;
    border-radius: var(--radius-sm);
    background: var(--lime);
    color: var(--bg1);
    flex-shrink: 0;
    animation: pw-new-pulse 2s ease-in-out infinite;
  }

  @keyframes pw-new-pulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--lime) 55%, transparent); }
    50%       { box-shadow: 0 0 0 5px color-mix(in srgb, var(--lime) 0%, transparent); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pw-new-badge { animation: none; }
  }

  .pw-image {
    height: 210px;
    background: var(--term-bg);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  .pw-img-el {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.9;
    mix-blend-mode: luminosity;
    transition: transform 0.4s ease;
  }

  .card-window:hover .pw-img-el { transform: scale(1.02); }

  .pw-content {
    padding: 1.5rem 1.75rem 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .pw-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.875rem;
  }

  .pw-type {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--lime);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--lime-dim);
    border: 1px solid rgba(158,255,87,0.2);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }

  .pw-year {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--dim);
  }

  .pw-title-text {
    font-family: var(--mono);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 0.6rem;
  }

  .pw-oneliner {
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--sub);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 0.875rem;
  }

  .pw-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .pw-tag {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--lime);
    background: var(--lime-dim);
    border: 1px solid rgba(158,255,87,0.2);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }
</style>
